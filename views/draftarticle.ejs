<!-- Toast -->
<div class="toast" id="toast"></div>

<script>
/* ── Theme ── */
const html = document.documentElement;
html.setAttribute('data-theme', localStorage.getItem('scribix-theme') || 'light');
document.getElementById('themeBtn').addEventListener('click', () => {
  const next = html.getAttribute('data-theme') === 'light' ? 'dark' : 'light';
  html.setAttribute('data-theme', next);
  localStorage.setItem('scribix-theme', next);
});

/* ── Nav scroll ── */
window.addEventListener('scroll', () => {
  document.getElementById('mainNav').classList.toggle('scrolled', window.scrollY > 20);
}, { passive: true });

/* ── Toast ── */
let _tt;
function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  clearTimeout(_tt);
  _tt = setTimeout(() => t.classList.remove('show'), 3200);
}

/* ── Animate progress bars on load ── */
const progressObs = new IntersectionObserver(entries => {
  entries.forEach(e => {
    if (e.isIntersecting) {
      e.target.querySelectorAll('.card-progress-fill, .wp-fill').forEach(fill => {
        const pct = fill.dataset.pct || fill.id === 'overallFill' ? fill.dataset.pct : fill.getAttribute('data-pct');
        setTimeout(() => { fill.style.width = pct + '%'; }, 100);
      });
      progressObs.unobserve(e.target);
    }
  });
}, { threshold: 0.1 });

document.querySelectorAll('.draft-card, .writing-progress').forEach(el => progressObs.observe(el));

/* Also fire overallFill on page load */
const overallFill = document.getElementById('overallFill');
setTimeout(() => { overallFill.style.width = overallFill.dataset.pct + '%'; }, 300);

/* ── View toggle ── */
const draftsGrid = document.getElementById('draftsGrid');
document.getElementById('gridViewBtn').addEventListener('click', function() {
  draftsGrid.classList.remove('list-view');
  document.getElementById('gridViewBtn').classList.add('active');
  document.getElementById('listViewBtn').classList.remove('active');
});
document.getElementById('listViewBtn').addEventListener('click', function() {
  draftsGrid.classList.add('list-view');
  document.getElementById('listViewBtn').classList.add('active');
  document.getElementById('gridViewBtn').classList.remove('active');
});

/* ── Filter chips ── */
let currentFilter = 'all';
document.querySelectorAll('.filter-chip').forEach(chip => {
  chip.addEventListener('click', function() {
    document.querySelectorAll('.filter-chip').forEach(c => c.classList.remove('active'));
    this.classList.add('active');
    currentFilter = this.dataset.filter;
    applyFilters();
  });
});

/* ── Search ── */
const searchInput = document.getElementById('searchInput');
document.getElementById('searchClear').addEventListener('click', () => {
  searchInput.value = '';
  searchInput.dispatchEvent(new Event('input'));
  searchInput.focus();
});
searchInput.addEventListener('input', applyFilters);

/* ── Sort ── */
document.getElementById('sortSelect').addEventListener('change', applyFilters);

function applyFilters() {
  const query = searchInput.value.toLowerCase().trim();
  const sort = document.getElementById('sortSelect').value;
  const cards = Array.from(document.querySelectorAll('.draft-card'));
  let visible = 0;

  // Sort
  const sorted = cards.sort((a, b) => {
    if (sort === 'progress') return parseInt(b.dataset.pct) - parseInt(a.dataset.pct);
    if (sort === 'words') return parseInt(b.dataset.words) - parseInt(a.dataset.words);
    if (sort === 'title') return a.dataset.title.localeCompare(b.dataset.title);
    return 0; // last edited — keep DOM order
  });

  // Reorder DOM
  sorted.forEach(card => draftsGrid.appendChild(card));

  // Filter + search
  document.querySelectorAll('.draft-card').forEach(card => {
    const matchFilter = currentFilter === 'all'
      || (currentFilter === 'high' && card.dataset.priority === 'high')
      || (currentFilter === 'ai' && card.dataset.category === 'ai')
      || (currentFilter === 'design' && card.dataset.category === 'design')
      || (currentFilter === 'other' && card.dataset.category === 'other');

    const matchSearch = !query || card.dataset.title.toLowerCase().includes(query)
      || card.querySelector('.card-snippet').textContent.toLowerCase().includes(query);

    const show = matchFilter && matchSearch;
    card.style.display = show ? '' : 'none';
    if (show) visible++;
  });

  // Show/hide empty state
  document.getElementById('emptyState').style.display = visible === 0 ? 'flex' : 'none';

  // Update count
  document.getElementById('navCount').textContent = visible;
  document.getElementById('totalDrafts').textContent = visible;
}

/* ── Kebab menu ── */
let openMenu = null;
function toggleMenu(e, btn) {
  e.stopPropagation();
  const dd = btn.nextElementSibling;
  if (openMenu && openMenu !== dd) openMenu.classList.remove('open');
  dd.classList.toggle('open');
  openMenu = dd.classList.contains('open') ? dd : null;
}
window.toggleMenu = toggleMenu;

document.addEventListener('click', () => {
  if (openMenu) { openMenu.classList.remove('open'); openMenu = null; }
});

function handleDD(action) {
  const msgs = {
    duplicate: '⎘ Draft duplicated!',
    rename: '✏️ Opening rename…',
    move: '📂 Move to folder',
    export: '↗ Exporting draft…',
  };
  showToast(msgs[action] || '✓ Done');
  if (openMenu) { openMenu.classList.remove('open'); openMenu = null; }
}
window.handleDD = handleDD;

/* ── Delete ── */
let cardToDelete = null;
const deleteModal = document.getElementById('deleteModal');
const deleteDraftName = document.getElementById('deleteDraftName');

function openDeleteModal(el) {
  const card = el.closest('.draft-card');
  cardToDelete = card;
  const title = card.dataset.title || card.querySelector('.card-title').textContent;
  deleteDraftName.textContent = '"' + title.substring(0, 50) + (title.length > 50 ? '…' : '') + '"';
  deleteModal.classList.add('open');
  if (openMenu) { openMenu.classList.remove('open'); openMenu = null; }
}
window.openDeleteModal = openDeleteModal;

document.getElementById('cancelDelete').addEventListener('click', () => {
  deleteModal.classList.remove('open');
  cardToDelete = null;
});

document.getElementById('confirmDelete').addEventListener('click', () => {
  if (cardToDelete) {
    cardToDelete.style.transition = 'all .3s ease';
    cardToDelete.style.opacity = '0';
    cardToDelete.style.transform = 'scale(.9)';
    setTimeout(() => {
      cardToDelete.remove();
      cardToDelete = null;
      deleteModal.classList.remove('open');
      showToast('🗑 Draft deleted');
      applyFilters();
    }, 300);
  }
});

deleteModal.addEventListener('click', e => {
  if (e.target === deleteModal) { deleteModal.classList.remove('open'); cardToDelete = null; }
});

/* ── Navigate to write ── */
function goWrite() { window.location.href = 'scribix-write.html'; }
window.goWrite = goWrite;
</script>
