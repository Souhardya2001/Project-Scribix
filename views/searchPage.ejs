<script>
/* ── Theme ── */
const html = document.documentElement;
html.setAttribute('data-theme', localStorage.getItem('scribix-theme') || 'light');
document.getElementById('themeToggle').addEventListener('click', () => {
  const next = html.getAttribute('data-theme') === 'light' ? 'dark' : 'light';
  html.setAttribute('data-theme', next);
  localStorage.setItem('scribix-theme', next);
});

/* ── Navbar scroll ── */
window.addEventListener('scroll', () => {
  document.getElementById('mainNav').classList.toggle('scrolled', window.scrollY > 20);
}, { passive: true });

/* ── Toast ── */
let _tt;
function toast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  clearTimeout(_tt);
  _tt = setTimeout(() => t.classList.remove('show'), 3000);
}

/* ── Search logic ── */
function updateSearchUI(query) {
  query = query.trim();
  if (!query) return;

  document.getElementById('mainSearchInput').value = query;
  document.getElementById('navSearchInput').value = query;
  document.getElementById('crumbQuery').textContent = query;
  document.getElementById('metaQuery').textContent = `"${query}"`;

  // Highlight query terms in cards
  const terms = query.toLowerCase().split(/\s+/).filter(w => w.length > 2);
  document.querySelectorAll('.highlight').forEach(el => {
    el.classList.remove('highlight');
  });

  document.querySelectorAll('.result-card .card-title').forEach(title => {
    let html = title.textContent;
    terms.forEach(term => {
      const re = new RegExp(`(${term})`, 'gi');
      html = html.replace(re, '<span class="highlight">$1</span>');
    });
    title.innerHTML = html;
  });

  toast(`Searching for "${query}"…`);
  document.getElementById('resultsList').style.opacity = '0.5';
  setTimeout(() => {
    document.getElementById('resultsList').style.opacity = '1';
    document.getElementById('resultsList').style.transition = 'opacity .35s ease';
  }, 600);
}

function doSearch(query) {
  updateSearchUI(query);
  document.getElementById('mainSearchInput').focus();
}
window.doSearch = doSearch;

/* Main search bar */
document.getElementById('mainSearchInput').addEventListener('keydown', e => {
  if (e.key === 'Enter') doSearch(e.target.value);
});
document.getElementById('searchBtn').addEventListener('click', () => {
  doSearch(document.getElementById('mainSearchInput').value);
});

/* Nav search bar */
document.getElementById('navSearchInput').addEventListener('keydown', e => {
  if (e.key === 'Enter') doSearch(e.target.value);
});
document.getElementById('navSearchClear').addEventListener('click', () => {
  document.getElementById('navSearchInput').value = '';
  document.getElementById('mainSearchInput').value = '';
  document.getElementById('navSearchInput').focus();
});

/* Suggestion chips */
document.querySelectorAll('.suggest-chip').forEach(chip => {
  chip.addEventListener('click', () => doSearch(chip.dataset.query));
});

/* ── Filter chips ── */
document.querySelectorAll('.filter-chip').forEach(chip => {
  chip.addEventListener('click', function() {
    document.querySelectorAll('.filter-chip').forEach(c => c.classList.remove('active'));
    this.classList.add('active');
    toast(`Filtered: ${this.textContent.replace(/\d+(\.\d+)?K?/g,'').trim()}`);
  });
});

/* ── Sort select ── */
document.getElementById('sortSelect').addEventListener('change', function() {
  toast(`Sorted by: ${this.value}`);
});

/* ── Save / Share ── */
function toggleSave(e, btn) {
  e.stopPropagation();
  const saved = btn.classList.toggle('saved');
  btn.innerHTML = saved
    ? `<svg width="13" height="13" fill="currentColor" viewBox="0 0 24 24"><path d="M19 21l-7-5-7 5V5a2 2 0 012-2h10a2 2 0 012 2z"/></svg>`
    : `<svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M19 21l-7-5-7 5V5a2 2 0 012-2h10a2 2 0 012 2z"/></svg>`;
  toast(saved ? '🔖 Saved to your library!' : 'Removed from library');
}
window.toggleSave = toggleSave;

function shareArticle(e) {
  e.stopPropagation();
  navigator.clipboard.writeText(window.location.href).catch(() => {});
  toast('🔗 Link copied to clipboard!');
}
window.shareArticle = shareArticle;

function openArticle(card) {
  const title = card.querySelector('.card-title').textContent;
  window.location.href = 'scribix-article.html';
}
window.openArticle = openArticle;

/* ── Follow ── */
function toggleFollow(btn) {
  const following = btn.classList.toggle('following');
  const name = btn.closest('.author-suggest').querySelector('.as-name').textContent;
  btn.textContent = following ? '✓' : 'Follow';
  toast(following ? `✅ Following ${name}` : `Unfollowed ${name}`);
}
window.toggleFollow = toggleFollow;

/* ── Tags ── */
function filterByTag(btn, tag) {
  document.querySelectorAll('.tag-pill').forEach(p => p.classList.remove('active'));
  btn.classList.add('active');
  doSearch(tag);
}
window.filterByTag = filterByTag;

/* ── History ── */
function removeHistory(e, btn) {
  e.stopPropagation();
  btn.closest('.history-item').remove();
  toast('Search removed');
}
window.removeHistory = removeHistory;

function clearHistory() {
  document.getElementById('historyList').innerHTML = '<div style="font-size:13px;color:var(--ink-4);padding:8px 10px;">No recent searches</div>';
  toast('History cleared');
}
window.clearHistory = clearHistory;

/* ── Load more ── */
let page = 1;
document.getElementById('loadMoreBtn').addEventListener('click', function() {
  this.textContent = 'Loading…';
  this.disabled = true;
  setTimeout(() => {
    page++;
    toast(`Loaded page ${page}`);
    this.innerHTML = `<svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 5v14M5 12l7 7 7-7"/></svg> Load more results`;
    this.disabled = false;
  }, 1000);
});

/* ── Scroll reveal ── */
const observer = new IntersectionObserver((entries) => {
  entries.forEach(entry => {
    if (entry.isIntersecting) {
      entry.target.style.opacity = '1';
      entry.target.style.transform = 'translateY(0)';
      observer.unobserve(entry.target);
    }
  });
}, { threshold: 0.08 });

document.querySelectorAll('.result-card').forEach((card, i) => {
  card.style.transition = `opacity .45s ease ${i * 0.07}s, transform .45s ease ${i * 0.07}s, border-color .22s ease, box-shadow .22s ease`;
  observer.observe(card);
});

/* ── Read URL params to pre-fill search ── */
const params = new URLSearchParams(window.location.search);
const q = params.get('q');
if (q) {
  document.getElementById('mainSearchInput').value = q;
  document.getElementById('navSearchInput').value = q;
  document.getElementById('crumbQuery').textContent = q;
  document.getElementById('metaQuery').textContent = `"${q}"`;
}
</script>
