<!-- Toast -->
<div class="toast" id="toast"></div>

<script>
/* ── Theme ── */
const themeBtn = document.getElementById('themeBtn');
const html = document.documentElement;
const saved = localStorage.getItem('scribix-theme') || 'light';
html.setAttribute('data-theme', saved);
themeBtn.addEventListener('click', () => {
  const next = html.getAttribute('data-theme') === 'light' ? 'dark' : 'light';
  html.setAttribute('data-theme', next);
  localStorage.setItem('scribix-theme', next);
});

/* ── Toast ── */
function toast(msg, type = 'success') {
  const el = document.getElementById('toast');
  el.textContent = msg;
  el.className = `toast ${type} show`;
  setTimeout(() => el.classList.remove('show'), 3400);
}

/* ── Password eye toggles ── */
function makeEye(btnId, inputId, openId, closeId) {
  document.getElementById(btnId).addEventListener('click', () => {
    const inp = document.getElementById(inputId);
    const shown = inp.type === 'text';
    inp.type = shown ? 'password' : 'text';
    document.getElementById(openId).style.display  = shown ? 'block' : 'none';
    document.getElementById(closeId).style.display = shown ? 'none'  : 'block';
  });
}
makeEye('pwEye1','password','eye1O','eye1C');
makeEye('pwEye2','confirm', 'eye2O','eye2C');

/* ── Password strength ── */
const pw = document.getElementById('password');
const strengthWrap = document.getElementById('strengthWrap');
const segs = [document.getElementById('s1'),document.getElementById('s2'),document.getElementById('s3'),document.getElementById('s4')];
const strengthLabel = document.getElementById('strengthLabel');
const levels = [
  {label:'Too weak',  cls:'s1', color:'#f87171'},
  {label:'Weak',      cls:'s2', color:'#fb923c'},
  {label:'Fair',      cls:'s3', color:'#facc15'},
  {label:'Strong 💪', cls:'s4', color:'#4ade80'},
];
function calcStrength(v) {
  let score = 0;
  if (v.length >= 8)  score++;
  if (/[A-Z]/.test(v)) score++;
  if (/[0-9]/.test(v)) score++;
  if (/[^A-Za-z0-9]/.test(v)) score++;
  return score;
}
pw.addEventListener('input', () => {
  const v = pw.value;
  if (!v) { strengthWrap.style.display = 'none'; return; }
  strengthWrap.style.display = 'block';
  const score = calcStrength(v);
  segs.forEach((s, i) => {
    s.className = 'strength-seg';
    if (i < score) s.classList.add(levels[score - 1].cls);
  });
  const lvl = levels[Math.min(score, 4) - 1] || levels[0];
  strengthLabel.textContent = lvl.label;
  strengthLabel.style.color = lvl.color;
});

/* ── Username availability simulation ── */
const takenNames = ['aria','admin','scribix','test','user','root'];
let userTimer;
document.getElementById('username').addEventListener('input', function () {
  const val = this.value.trim().toLowerCase();
  const hint = document.getElementById('userHint');
  clearTimeout(userTimer);
  if (!val) { hint.className = 'field-hint hint-check'; hint.textContent = 'Enter a username'; return; }
  hint.className = 'field-hint hint-check'; hint.textContent = 'Checking…';
  userTimer = setTimeout(() => {
    if (takenNames.includes(val)) {
      hint.className = 'field-hint hint-err';
      hint.textContent = '✕ @' + val + ' is taken';
    } else if (val.length < 3) {
      hint.className = 'field-hint hint-err';
      hint.textContent = 'Too short (min 3 chars)';
    } else {
      hint.className = 'field-hint hint-ok';
      hint.textContent = '✓ @' + val + ' is available!';
    }
  }, 600);
});

/* ── Field error helpers ── */
function setErr(id, show) {
  document.getElementById(id).classList.toggle('error', show);
}
function clearErr(inputId, fieldId) {
  document.getElementById(inputId).addEventListener('input', () => setErr(fieldId, false));
}
clearErr('fullName','fName');
clearErr('email','fEmail');
clearErr('password','fPass');
clearErr('confirm','fConf');

/* ── Confirm match live check ── */
document.getElementById('confirm').addEventListener('input', function () {
  const match = this.value === pw.value && this.value.length > 0;
  document.getElementById('fConf').classList.toggle('valid', match);
  if (match) setErr('fConf', false);
});

/* ── Validate email ── */
const isEmail = v => /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v);

/* ── Form submit ── */
const form = document.getElementById('signupForm');
const submitBtn = document.getElementById('submitBtn');

form.addEventListener('submit', async e => {
  e.preventDefault();
  const name  = document.getElementById('fullName').value.trim();
  const uname = document.getElementById('username').value.trim();
  const email = document.getElementById('email').value.trim();
  const pass  = pw.value;
  const conf  = document.getElementById('confirm').value;
  const terms = document.getElementById('terms').checked;

  let ok = true;
  if (!name)           { setErr('fName',  true); ok = false; }
  if (uname.length < 3){ setErr('fUser',  true); ok = false; }
  if (!isEmail(email)) { setErr('fEmail', true); ok = false; }
  if (pass.length < 8) { setErr('fPass',  true); ok = false; }
  if (pass !== conf)   { setErr('fConf',  true); ok = false; }
  if (!terms)          { toast('Please agree to the Terms of Service.', 'error'); ok = false; }
  if (!ok) return;

  submitBtn.classList.add('loading');
  submitBtn.disabled = true;

  await new Promise(r => setTimeout(r, 2000));

  submitBtn.classList.remove('loading');
  submitBtn.disabled = false;
  toast('Account created! Welcome to Scribix 🎉', 'success');
  setTimeout(() => toast('(Demo mode — connect backend to redirect)', 'info'), 2800);
});

/* ── Google demo ── */
document.getElementById('googleBtn').addEventListener('click', e => {
  e.preventDefault();
  toast('Redirecting to Google OAuth…', 'info');
});
</script>
</body>
