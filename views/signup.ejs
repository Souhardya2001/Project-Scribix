<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Sign Up — Scribix</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;500;600;700;800&family=DM+Serif+Display:ital@0;1&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
  <style>
/* ════════════════════════════════════════════
   SCRIBIX SIGNUP — Full Premium CSS
════════════════════════════════════════════ */
:root {
  --bg:            #f4f2ff;
  --bg-panel:      #ffffff;
  --bg-input:      #faf9ff;
  --bg-input-hover:#f3f0ff;
  --border:        #e2ddf5;
  --border-focus:  #7c3aed;
  --text-primary:  #0c0820;
  --text-secondary:#574e72;
  --text-muted:    #9890b5;
  --accent:        #7c3aed;
  --accent-2:      #0ea5e9;
  --gradient:      linear-gradient(135deg,#7c3aed 0%,#0ea5e9 100%);
  --gradient-r:    linear-gradient(135deg,#0ea5e9 0%,#7c3aed 100%);
  --gradient-soft: linear-gradient(135deg,#a78bfa1a,#38bdf81a);
  --gradient-text: linear-gradient(135deg,#a78bfa,#38bdf8);
  --shadow-xs:     0 1px 3px rgba(124,58,237,.06);
  --shadow-sm:     0 2px 8px rgba(124,58,237,.08);
  --shadow-md:     0 8px 32px rgba(124,58,237,.13);
  --shadow-lg:     0 24px 64px rgba(124,58,237,.18);
  --shadow-ring:   0 0 0 3px rgba(124,58,237,.13);
  --radius:        14px;
  --font:          'Sora', system-ui, sans-serif;
  --font-display:  'DM Serif Display', Georgia, serif;
  --font-mono:     'JetBrains Mono', monospace;
  --ease:          cubic-bezier(.4,0,.2,1);
  --spring:        cubic-bezier(.34,1.56,.64,1);
  --t:             .22s;

  /* left panel colours */
  --lp-bg:         #0d0820;
  --lp-card:       rgba(255,255,255,.05);
  --lp-border:     rgba(255,255,255,.09);
}
[data-theme="dark"] {
  --bg:            #09090f;
  --bg-panel:      #111020;
  --bg-input:      #1a182e;
  --bg-input-hover:#211f35;
  --border:        #29263f;
  --border-focus:  #a78bfa;
  --text-primary:  #ede9ff;
  --text-secondary:#a49cc0;
  --text-muted:    #6b6285;
  --shadow-md:     0 8px 32px rgba(0,0,0,.45);
  --shadow-lg:     0 24px 64px rgba(0,0,0,.55);
  --shadow-ring:   0 0 0 3px rgba(167,139,250,.17);
}

*,*::before,*::after { box-sizing: border-box; margin: 0; padding: 0; }
html { -webkit-font-smoothing: antialiased; height: 100%; }
body {
  font-family: var(--font);
  background: var(--bg);
  color: var(--text-primary);
  min-height: 100vh;
  display: flex;
  transition: background var(--t) var(--ease), color var(--t) var(--ease);
  overflow-x: hidden;
}

/* ────────────────────────────
   TWO-COLUMN LAYOUT
──────────────────────────── */
.page {
  display: grid;
  grid-template-columns: 1fr 1fr;
  min-height: 100vh;
  width: 100%;
}

/* ════════════════════════════
   LEFT PANEL — dark branded
════════════════════════════ */
.lp {
  background: var(--lp-bg);
  position: relative;
  display: flex;
  flex-direction: column;
  padding: 36px 48px 40px;
  overflow: hidden;
}

/* mesh orbs */
.orb {
  position: absolute;
  border-radius: 50%;
  filter: blur(72px);
  pointer-events: none;
  will-change: transform;
}
.o1 { width:440px;height:440px;background:radial-gradient(circle,#7c3aed4d,transparent 68%);top:-100px;right:-130px;animation:drft1 10s ease-in-out infinite alternate; }
.o2 { width:360px;height:360px;background:radial-gradient(circle,#0ea5e940,transparent 68%);bottom:-80px;left:-100px;animation:drft2 12s ease-in-out infinite alternate; }
.o3 { width:260px;height:260px;background:radial-gradient(circle,#a78bfa30,transparent 68%);top:42%;left:28%;animation:drft1 8s ease-in-out 1.5s infinite alternate;opacity:.7; }
.o4 { width:180px;height:180px;background:radial-gradient(circle,#38bdf828,transparent 68%);top:20%;left:10%;animation:drft2 6s ease-in-out 3s infinite alternate; }
@keyframes drft1{from{transform:translate(0,0) scale(1);}to{transform:translate(22px,30px) scale(1.06);}}
@keyframes drft2{from{transform:translate(0,0) scale(1);}to{transform:translate(-18px,22px) scale(1.08);}}

/* dot grid */
.dot-grid {
  position:absolute;inset:0;
  background-image: radial-gradient(circle,rgba(255,255,255,.07) 1px,transparent 1px);
  background-size: 30px 30px;
  pointer-events:none;
}
/* right edge glow line */
.lp::after {
  content:'';position:absolute;right:0;top:0;bottom:0;width:1px;
  background:linear-gradient(to bottom,transparent,rgba(167,139,250,.45) 30%,rgba(56,189,248,.45) 70%,transparent);
}

/* logo */
.lp-logo {
  position:relative;z-index:2;
  display:inline-flex;align-items:center;gap:10px;
  text-decoration:none;
}
.lp-logo-icon {
  width:38px;height:38px;
  background:rgba(255,255,255,.07);
  border:1px solid rgba(167,139,250,.3);
  border-radius:11px;
  display:flex;align-items:center;justify-content:center;
  backdrop-filter:blur(8px);
}
.lp-logo-text {
  font-size:21px;font-weight:700;
  background:linear-gradient(135deg,#c4b5fd,#7dd3fc);
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
}

/* centre hero area */
.lp-hero {
  position:relative;z-index:2;
  flex:1;display:flex;flex-direction:column;justify-content:center;
  padding:48px 0 32px;
}

/* SVG illustration area */
.lp-illustration {
  margin-bottom:36px;
  display:flex;justify-content:flex-start;
}

/* eyebrow */
.lp-eyebrow {
  display:inline-flex;align-items:center;gap:8px;
  padding:5px 14px;
  background:rgba(167,139,250,.12);
  border:1px solid rgba(167,139,250,.22);
  border-radius:50px;
  font-size:11.5px;font-weight:600;letter-spacing:1px;
  color:#c4b5fd;text-transform:uppercase;
  margin-bottom:22px;width:fit-content;
}
.eyebrow-dot {
  width:6px;height:6px;
  background:#a78bfa;border-radius:50%;
  animation:blink 2s ease infinite;
}
@keyframes blink{0%,100%{opacity:1;}50%{opacity:.25;}}

.lp-headline {
  font-family:var(--font-display);
  font-size:clamp(30px,3vw,48px);
  font-weight:400;line-height:1.18;
  color:#fff;margin-bottom:18px;
}
.lp-headline em {
  font-style:italic;
  background:linear-gradient(135deg,#c4b5fd,#7dd3fc);
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
}
.lp-sub {
  font-size:14.5px;color:rgba(255,255,255,.45);
  line-height:1.75;max-width:360px;margin-bottom:36px;
}

/* stats row */
.lp-stats {
  display:flex;gap:28px;flex-wrap:wrap;margin-bottom:40px;
}
.lp-stat { display:flex;flex-direction:column;gap:3px; }
.lp-stat strong {
  font-size:22px;font-weight:700;
  background:linear-gradient(135deg,#c4b5fd,#7dd3fc);
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
}
.lp-stat span { font-size:11.5px;color:rgba(255,255,255,.38);letter-spacing:.5px;text-transform:uppercase; }

/* stack of feature cards */
.lp-cards { display:flex;flex-direction:column;gap:12px; }
.lp-card {
  background:var(--lp-card);
  border:1px solid var(--lp-border);
  border-radius:13px;
  padding:14px 18px;
  display:flex;align-items:center;gap:14px;
  backdrop-filter:blur(8px);
  transition:background var(--t) var(--ease);
  animation:fadeInLft .5s var(--ease) both;
}
.lp-card:nth-child(2){animation-delay:.1s;}
.lp-card:nth-child(3){animation-delay:.2s;}
.lp-card:hover{background:rgba(255,255,255,.08);}
@keyframes fadeInLft{from{opacity:0;transform:translateX(-16px);}to{opacity:1;transform:translateX(0);}}
.lp-card-icon {
  width:38px;height:38px;border-radius:10px;
  background:rgba(255,255,255,.06);
  border:1px solid rgba(255,255,255,.1);
  display:flex;align-items:center;justify-content:center;
  font-size:16px;flex-shrink:0;
}
.lp-card-text strong{display:block;font-size:13px;font-weight:600;color:rgba(255,255,255,.82);margin-bottom:2px;}
.lp-card-text span{font-size:11.5px;color:rgba(255,255,255,.35);}

/* avatar row at bottom */
.lp-bottom { position:relative;z-index:2; }
.lp-join {
  display:flex;align-items:center;gap:14px;
  padding:16px 20px;
  background:rgba(255,255,255,.05);
  border:1px solid rgba(255,255,255,.09);
  border-radius:14px;
  backdrop-filter:blur(8px);
}
.lp-avatars {
  display:flex;
}
.lp-av {
  width:32px;height:32px;border-radius:50%;
  border:2.5px solid rgba(13,8,32,.8);
  object-fit:cover;
  margin-right:-10px;
  flex-shrink:0;
}
.lp-av:last-child{margin-right:0;}
.lp-join-text strong{display:block;font-size:13px;font-weight:700;color:rgba(255,255,255,.85);}
.lp-join-text span{font-size:11.5px;color:rgba(255,255,255,.38);}

/* ════════════════════════════
   RIGHT PANEL — form
════════════════════════════ */
.rp {
  background:var(--bg-panel);
  display:flex;flex-direction:column;
  justify-content:center;align-items:center;
  padding:40px 36px;
  position:relative;
  transition:background var(--t) var(--ease);
}

/* top bar controls */
.rp-bar {
  position:absolute;top:0;left:0;right:0;
  display:flex;align-items:center;justify-content:space-between;
  padding:18px 24px;
}
.back-link {
  display:flex;align-items:center;gap:7px;
  font-size:13px;font-weight:500;
  color:var(--text-muted);text-decoration:none;
  transition:color var(--t) var(--ease);
}
.back-link:hover{color:var(--accent);}
.back-link svg{transition:transform var(--t) var(--ease);}
.back-link:hover svg{transform:translateX(-3px);}
.theme-btn {
  width:36px;height:36px;border-radius:9px;
  background:var(--bg-input);border:1px solid var(--border);
  display:flex;align-items:center;justify-content:center;
  font-size:15px;cursor:pointer;
  transition:all var(--t) var(--ease);
}
.theme-btn:hover{border-color:var(--border-focus);transform:scale(1.05);}
.moon-ic{display:none;}
[data-theme="dark"] .sun-ic{display:none;}
[data-theme="dark"] .moon-ic{display:block;}

/* form wrapper */
.form-wrap {
  width:100%;max-width:420px;
  animation:formIn .55s var(--spring) both;
}
@keyframes formIn{from{opacity:0;transform:translateY(22px);}to{opacity:1;transform:translateY(0);}}

/* header */
.fh { margin-bottom:26px; }
.fh-tag {
  display:inline-flex;align-items:center;gap:6px;
  font-size:12px;font-weight:600;letter-spacing:.5px;
  color:var(--accent);margin-bottom:8px;
}
.fh-tag-dot {
  width:5px;height:5px;background:var(--gradient);border-radius:50%;
}
.fh-title {
  font-family:var(--font-display);
  font-size:clamp(24px,2.8vw,32px);
  font-weight:400;line-height:1.2;
  color:var(--text-primary);margin-bottom:8px;
}
.fh-title em {
  font-style:italic;
  background:var(--gradient-text);
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
}
.fh-sub { font-size:13.5px;color:var(--text-muted);line-height:1.6; }

/* Google btn */
.btn-google {
  display:flex;align-items:center;justify-content:center;gap:10px;
  width:100%;padding:12px 18px;
  border-radius:12px;border:1.5px solid var(--border);
  background:var(--bg-input);
  color:var(--text-primary);
  font-size:13.5px;font-weight:600;font-family:var(--font);
  cursor:pointer;text-decoration:none;
  transition:all var(--t) var(--ease);margin-bottom:20px;
}
.btn-google:hover {
  border-color:var(--border-focus);
  background:var(--gradient-soft);
  transform:translateY(-2px);box-shadow:var(--shadow-md);
}
.g-logo{width:19px;height:19px;flex-shrink:0;}

/* divider */
.divider {
  display:flex;align-items:center;gap:12px;
  margin-bottom:20px;
  font-size:12px;font-weight:500;color:var(--text-muted);
}
.divider::before,.divider::after{content:'';flex:1;height:1px;background:var(--border);}

/* name row — two fields side by side */
.row-2 { display:grid;grid-template-columns:1fr 1fr;gap:12px; }

/* field */
.field { margin-bottom:14px; }
.field-lbl {
  display:flex;align-items:center;justify-content:space-between;
  font-size:12.5px;font-weight:600;
  color:var(--text-secondary);margin-bottom:6px;
}
.field-lbl .optional {
  font-size:11px;font-weight:400;color:var(--text-muted);
}
.input-wrap { position:relative; }
.field-ico {
  position:absolute;left:13px;top:50%;transform:translateY(-50%);
  color:var(--text-muted);pointer-events:none;
  transition:color var(--t) var(--ease);flex-shrink:0;
}
.field-input {
  width:100%;
  padding:12px 13px 12px 40px;
  border-radius:11px;
  border:1.5px solid var(--border);
  background:var(--bg-input);
  color:var(--text-primary);
  font-size:13.5px;font-family:var(--font);
  outline:none;
  transition:all var(--t) var(--ease);
  appearance:none;
}
.field-input::placeholder{color:var(--text-muted);}
.field-input:hover{background:var(--bg-input-hover);}
.field-input:focus {
  border-color:var(--border-focus);
  background:var(--bg-panel);
  box-shadow:var(--shadow-ring);
}
.input-wrap:focus-within .field-ico{color:var(--accent);}

/* password strength */
.strength-wrap{margin-top:7px;}
.strength-bar {
  display:grid;grid-template-columns:repeat(4,1fr);gap:4px;margin-bottom:5px;
}
.strength-seg {
  height:3px;border-radius:2px;
  background:var(--border);
  transition:background .3s var(--ease);
}
.strength-seg.s1{background:#f87171;}
.strength-seg.s2{background:#fb923c;}
.strength-seg.s3{background:#facc15;}
.strength-seg.s4{background:#4ade80;}
.strength-label{font-size:11px;color:var(--text-muted);}

/* password eye toggle */
.pw-eye {
  position:absolute;right:13px;top:50%;transform:translateY(-50%);
  color:var(--text-muted);cursor:pointer;
  display:flex;align-items:center;
  transition:color var(--t) var(--ease);
}
.pw-eye:hover{color:var(--accent);}

/* username prefix */
.input-prefix {
  position:absolute;left:13px;top:50%;transform:translateY(-50%);
  font-size:13.5px;font-weight:500;color:var(--text-muted);
  pointer-events:none;font-family:var(--font-mono);
}
.has-prefix .field-input { padding-left:30px; }

/* username availability */
.field-hint {
  font-size:11px;margin-top:5px;
  display:flex;align-items:center;gap:5px;
}
.hint-ok{color:#4ade80;}
.hint-err{color:#f87171;}
.hint-check{color:var(--text-muted);}

/* field error */
.field-err {
  font-size:11.5px;color:#f87171;font-weight:500;
  margin-top:5px;display:none;
}
.field.error .field-input{border-color:#f87171;box-shadow:0 0 0 3px rgba(248,113,113,.13);}
.field.error .field-err{display:block;}
.field.error .field-ico{color:#f87171;}

/* confirm match check */
.field.valid .field-input { border-color:#4ade80; }

/* terms row */
.terms-row {
  display:flex;align-items:flex-start;gap:10px;
  margin-bottom:20px;
  font-size:13px;color:var(--text-secondary);line-height:1.55;
}
.terms-row input[type="checkbox"]{display:none;}
.cb-box {
  width:18px;height:18px;flex-shrink:0;
  border-radius:5px;border:1.5px solid var(--border);
  background:var(--bg-input);
  display:flex;align-items:center;justify-content:center;
  cursor:pointer;margin-top:1px;
  transition:all var(--t) var(--ease);
}
.terms-row input:checked + .cb-box {
  background:var(--gradient);border-color:transparent;
}
.cb-box svg{display:none;}
.terms-row input:checked + .cb-box svg{display:block;}
.terms-row a{color:var(--accent);font-weight:600;text-decoration:none;}
.terms-row a:hover{opacity:.75;}

/* submit */
.btn-submit {
  width:100%;padding:13px 20px;
  border-radius:12px;
  background:var(--gradient);
  color:#fff;font-size:14.5px;font-weight:700;font-family:var(--font);
  border:none;cursor:pointer;
  display:flex;align-items:center;justify-content:center;gap:9px;
  box-shadow:0 6px 22px rgba(124,58,237,.38);
  transition:all var(--t) var(--ease);
  position:relative;overflow:hidden;
  margin-bottom:20px;
}
.btn-submit::before {
  content:'';position:absolute;inset:0;
  background:linear-gradient(135deg,rgba(255,255,255,.16),transparent);
  opacity:0;transition:opacity var(--t) var(--ease);
}
.btn-submit:hover{transform:translateY(-2px);box-shadow:0 10px 32px rgba(124,58,237,.46);}
.btn-submit:hover::before{opacity:1;}
.btn-submit:active{transform:translateY(0);}
.btn-submit.loading .btn-label{display:none;}
.btn-submit .spinner{
  width:18px;height:18px;
  border:2px solid rgba(255,255,255,.3);
  border-top-color:#fff;
  border-radius:50%;display:none;
  animation:spin .7s linear infinite;
}
.btn-submit.loading .spinner{display:block;}
@keyframes spin{to{transform:rotate(360deg);}}

/* login link */
.login-row {
  text-align:center;font-size:13px;color:var(--text-muted);
}
.login-row a{font-weight:700;color:var(--accent);text-decoration:none;}
.login-row a:hover{opacity:.75;}

/* stagger */
.btn-google{animation:fuA .4s .04s var(--ease) both;}
.divider{animation:fuA .4s .08s var(--ease) both;}
.row-2{animation:fuA .4s .12s var(--ease) both;}
.field:nth-child(1){animation:fuA .4s .15s var(--ease) both;}
.field:nth-child(2){animation:fuA .4s .19s var(--ease) both;}
.field:nth-child(3){animation:fuA .4s .23s var(--ease) both;}
.field:nth-child(4){animation:fuA .4s .27s var(--ease) both;}
.terms-row{animation:fuA .4s .31s var(--ease) both;}
.btn-submit{animation:fuA .4s .35s var(--ease) both;}
.login-row{animation:fuA .4s .39s var(--ease) both;}
@keyframes fuA{from{opacity:0;transform:translateY(12px);}to{opacity:1;transform:translateY(0);}}

/* ── Toast ── */
.toast {
  position:fixed;bottom:24px;left:50%;
  transform:translateX(-50%) translateY(70px);
  background:#12102a;color:#fff;
  padding:11px 22px;border-radius:50px;
  font-size:13px;font-weight:600;
  box-shadow:0 8px 30px rgba(0,0,0,.32);
  display:flex;align-items:center;gap:9px;
  transition:transform .35s var(--spring),opacity .25s var(--ease);
  opacity:0;z-index:9999;white-space:nowrap;
  border:1px solid rgba(255,255,255,.1);
}
.toast.show{transform:translateX(-50%) translateY(0);opacity:1;}
.toast.success::before{content:'✓';color:#4ade80;font-weight:800;}
.toast.error::before{content:'✕';color:#f87171;font-weight:800;}
.toast.info::before{content:'ℹ';color:#38bdf8;font-weight:800;}

/* ── Responsive ── */
@media(max-width:900px){
  .page{grid-template-columns:1fr;}
  .lp{display:none;}
  .rp{min-height:100vh;padding:80px 20px 48px;}
}
@media(max-width:520px){
  .row-2{grid-template-columns:1fr;}
  .form-wrap{max-width:100%;}
}
  </style>
</head>
<body>
<div class="page">

  <!-- ═══════════════════════════════
       LEFT PANEL
  ═══════════════════════════════ -->
  <div class="lp">
    <div class="orb o1"></div>
    <div class="orb o2"></div>
    <div class="orb o3"></div>
    <div class="orb o4"></div>
    <div class="dot-grid"></div>

    <!-- Logo -->
    <a href="/homepage" class="lp-logo">
      <span class="lp-logo-icon">
        <svg width="22" height="22" viewBox="0 0 28 28" fill="none">
          <defs>
            <linearGradient id="llg" x1="0" y1="0" x2="28" y2="28">
              <stop stop-color="#a78bfa"/><stop offset="1" stop-color="#38bdf8"/>
            </linearGradient>
          </defs>
          <path d="M4 6C4 4.9 4.9 4 6 4h10l8 8v10c0 1.1-.9 2-2 2H6c-1.1 0-2-.9-2-2V6z" fill="url(#llg)" opacity=".25"/>
          <path d="M14 4l8 8h-6a2 2 0 01-2-2V4z" fill="url(#llg)" opacity=".6"/>
          <path d="M8 13h12M8 17h8" stroke="url(#llg)" stroke-width="1.8" stroke-linecap="round"/>
        </svg>
      </span>
      <span class="lp-logo-text">Scribix</span>
    </a>

    <!-- Hero -->
    <div class="lp-hero">

      <!-- Custom SVG Illustration -->
      <div class="lp-illustration">
        <svg width="320" height="200" viewBox="0 0 320 200" fill="none" xmlns="http://www.w3.org/2000/svg">
          <defs>
