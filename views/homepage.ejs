  margin: 0 auto 12px;
  border: 1px solid var(--border-hover);
}
.chat-welcome p {
  font-size: 14px;
  color: var(--text-secondary);
  line-height: 1.6;
}
.chat-welcome p:first-of-type {
  font-size: 15px;
  color: var(--text-primary);
  margin-bottom: 6px;
}
.chat-suggestions {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  justify-content: center;
}
.suggestion-chip {
  padding: 7px 13px;
