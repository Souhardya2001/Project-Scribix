/* ═══════════════════════════════════════
   FLOATING AI BUTTON
═══════════════════════════════════════ */
.fab-ai {
  position: fixed;
  bottom: 32px;
  right: 32px;
  z-index: 900;
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 14px 20px 14px 16px;
  background: linear-gradient(135deg, #7c3aed, #0ea5e9);
  color: #fff;
  border-radius: 50px;
  font-size: 15px;
  font-weight: 700;
  font-family: var(--font-body);
  box-shadow: 0 8px 32px rgba(124,58,237,0.5), 0 4px 16px rgba(0,0,0,0.2);
  transition: all var(--transition);
  overflow: visible;
}
.fab-ai:hover {
  transform: translateY(-3px) scale(1.04);
  box-shadow: 0 12px 40px rgba(124,58,237,0.6), 0 6px 20px rgba(0,0,0,0.3);
}
.fab-ai:active { transform: scale(0.97); }
.fab-label { font-size: 14px; font-weight: 700; letter-spacing: 0.5px; }
.fab-glow {
  position: absolute;
  inset: -4px;
  border-radius: 50px;
  background: linear-gradient(135deg, #a78bfa, #38bdf8);
  opacity: 0.4;
  filter: blur(10px);
  z-index: -1;
  animation: fabGlow 2.5s ease-in-out infinite;
}
@keyframes fabGlow {
  0%, 100% { opacity: 0.35; transform: scale(1); }
  50% { opacity: 0.55; transform: scale(1.08); }
}
.fab-pulse {
  position: absolute;
  top: 6px;
  right: 6px;
  width: 10px;
  height: 10px;
  background: #22c55e;
  border: 2px solid rgba(255,255,255,0.8);
  border-radius: 50%;
  animation: pulse 2s ease infinite;
}
@keyframes pulse {
  0%, 100% { box-shadow: 0 0 0 0 rgba(34,197,94,0.5); }
  50% { box-shadow: 0 0 0 6px rgba(34,197,94,0); }
}

/* ═══════════════════════════════════════
   AI CHAT WINDOW
═══════════════════════════════════════ */
.ai-chat-window {
  position: fixed;
  bottom: 100px;
  right: 32px;
  z-index: 950;
  width: 380px;
  max-height: 560px;
  background: var(--bg);
  border-radius: var(--radius-lg);
  border: 1.5px solid var(--border-hover);
  box-shadow: 0 24px 80px rgba(124,58,237,0.3), 0 12px 40px rgba(0,0,0,0.2);
  display: flex;
  flex-direction: column;
  transform-origin: bottom right;
  transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1), opacity 0.2s ease;
  overflow: hidden;
}
.ai-chat-window[aria-hidden="true"] {
  transform: scale(0.7) translateY(20px);
