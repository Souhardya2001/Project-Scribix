<!-- ───────────── AI CHAT WINDOW ───────────── -->
<div class="ai-chat-window" id="aiChatWindow" aria-hidden="true">
  <div class="chat-header">
    <div class="chat-header-left">
      <div class="chat-ai-icon">
        <svg width="20" height="20" viewBox="0 0 26 26" fill="none">
          <circle cx="13" cy="13" r="5" stroke="white" stroke-width="1.8"/>
          <path d="M13 2v3M13 21v3M2 13h3M21 13h3" stroke="white" stroke-width="1.5" stroke-linecap="round"/>
          <circle cx="13" cy="13" r="2" fill="white"/>
        </svg>
      </div>
      <div>
        <strong>Scribix AI</strong>
        <span class="chat-status"><span class="online-dot"></span>Online</span>
      </div>
    </div>
    <div class="chat-header-actions">
      <button class="chat-action-btn" id="minimizeChat" aria-label="Minimize" title="Minimize">
        <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14"/></svg>
      </button>
      <button class="chat-action-btn" id="closeChat" aria-label="Close" title="Close">
        <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M18 6L6 18M6 6l12 12"/></svg>
      </button>
    </div>
  </div>

  <div class="chat-body" id="chatBody">
    <!-- Welcome message -->
    <div class="chat-welcome">
      <div class="welcome-icon">
        <svg width="32" height="32" viewBox="0 0 26 26" fill="none">
          <defs><linearGradient id="wg" x1="0" y1="0" x2="26" y2="26"><stop stop-color="#a78bfa"/><stop offset="1" stop-color="#38bdf8"/></linearGradient></defs>
          <circle cx="13" cy="13" r="5" stroke="url(#wg)" stroke-width="1.8"/>
          <path d="M13 2v3M13 21v3M2 13h3M21 13h3M5.6 5.6l2.1 2.1M18.3 18.3l2.1 2.1M5.6 20.4l2.1-2.1M18.3 7.7l2.1-2.1" stroke="url(#wg)" stroke-width="1.5" stroke-linecap="round"/>
          <circle cx="13" cy="13" r="2.5" fill="url(#wg)"/>
        </svg>
      </div>
      <p><strong>Hey! I'm your Scribix AI assistant.</strong></p>
      <p>I can summarize articles, answer questions about content, help you write, or just chat. What's on your mind?</p>
    </div>

    <div class="chat-suggestions">
      <button class="suggestion-chip" onclick="sendSuggestion(this)">✨ Summarize the top article</button>
      <button class="suggestion-chip" onclick="sendSuggestion(this)">🖊️ Help me write an intro</button>
      <button class="suggestion-chip" onclick="sendSuggestion(this)">📊 What's trending today?</button>
      <button class="suggestion-chip" onclick="sendSuggestion(this)">🎨 Tips for better writing</button>
    </div>

    <div id="chatMessages"></div>
  </div>

  <div class="chat-footer">
    <div class="chat-input-wrap">
      <input type="text" class="chat-input" id="chatInput" placeholder="Ask me anything…" autocomplete="off"/>
      <button class="chat-send" id="chatSend" aria-label="Send">
        <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M22 2L11 13M22 2L15 22l-4-9-9-4 20-7z"/></svg>
      </button>
    </div>
    <p class="chat-disclaimer">Scribix AI may make mistakes. Verify important information.</p>
  </div>
</div>

<script>
/* ═══════════════════════════════════════
   SCRIBIX — App JavaScript
═══════════════════════════════════════ */

// ─── Theme Toggle ───
const themeToggle = document.getElementById('themeToggle');
const html = document.documentElement;

const savedTheme = localStorage.getItem('scribix-theme') || 'light';
html.setAttribute('data-theme', savedTheme);

themeToggle.addEventListener('click', () => {
  const current = html.getAttribute('data-theme');
  const next = current === 'light' ? 'dark' : 'light';
  html.setAttribute('data-theme', next);
  localStorage.setItem('scribix-theme', next);
});

// ─── Navbar scroll ───
const navbar = document.getElementById('navbar');
window.addEventListener('scroll', () => {
  navbar.classList.toggle('scrolled', window.scrollY > 40);
});

// ─── Mobile menu ───
const hamburger = document.getElementById('hamburger');
const mobileMenu = document.getElementById('mobileMenu');
hamburger.addEventListener('click', () => {
  mobileMenu.classList.toggle('open');
});
// close when link clicked
mobileMenu.querySelectorAll('a').forEach(a => {
  a.addEventListener('click', () => mobileMenu.classList.remove('open'));
});

// ─── Smooth nav link active on scroll ───
const sections = document.querySelectorAll('section[id]');
const navLinks = document.querySelectorAll('.nav-link');
const observer = new IntersectionObserver((entries) => {
  entries.forEach(entry => {
    if (entry.isIntersecting) {
      navLinks.forEach(l => l.classList.remove('active'));
      const active = document.querySelector(`.nav-link[href="#${entry.target.id}"]`);
      if (active) active.classList.add('active');
    }
  });
}, { threshold: 0.4 });
sections.forEach(s => observer.observe(s));

// ─── Save button toggle ───
document.querySelectorAll('.save-btn').forEach(btn => {
  btn.addEventListener('click', function () {
    const saved = this.classList.toggle('saved');
    this.style.color = saved ? '#7c3aed' : '';
    this.style.background = saved ? 'rgba(124,58,237,0.1)' : '';
    this.title = saved ? 'Unsave' : 'Save';
  });
});

// ─── Follow button toggle ───
document.querySelectorAll('.author-follow').forEach(btn => {
  btn.addEventListener('click', function () {
    const following = this.textContent.trim() === 'Follow';
    this.textContent = following ? 'Following ✓' : 'Follow';
    this.style.background = following ? 'transparent' : '';
    this.style.border = following ? '1.5px solid #7c3aed' : '';
    this.style.color = following ? '#7c3aed' : '';
  });
});

// ─── Scroll reveal ───
const revealObserver = new IntersectionObserver((entries) => {
  entries.forEach(entry => {
    if (entry.isIntersecting) {
      entry.target.style.opacity = '1';
      entry.target.style.transform = 'translateY(0)';
      revealObserver.unobserve(entry.target);
    }
  });
}, { threshold: 0.1, rootMargin: '0px 0px -60px 0px' });

const revealTargets = document.querySelectorAll(
  '.article-card, .author-card, .category-card, .feature-card, .testimonial-card'
);
revealTargets.forEach((el, i) => {
  el.style.opacity = '0';
  el.style.transform = 'translateY(28px)';
  el.style.transition = `opacity 0.5s ease ${i * 0.06}s, transform 0.5s ease ${i * 0.06}s`;
  revealObserver.observe(el);
});

// ─── AI Chat Window ───
const fabAI = document.getElementById('fabAI');
const aiChatWindow = document.getElementById('aiChatWindow');
const closeChat = document.getElementById('closeChat');
const minimizeChat = document.getElementById('minimizeChat');
const chatInput = document.getElementById('chatInput');
const chatSend = document.getElementById('chatSend');
const chatBody = document.getElementById('chatBody');
const chatMessages = document.getElementById('chatMessages');

let isMinimized = false;
let isOpen = false;

// AI responses pool
const aiResponses = [
  "Great question! Based on the trending content on Scribix, AI writing tools are dominating the conversation. Writers are particularly interested in maintaining their authentic voice while using AI assistance.",
  "I can help you craft a compelling introduction! Start with a surprising statistic, a provocative question, or a vivid scene that drops readers directly into your story.",
  "Today's trending topics on Scribix include: AI & automation in creative work, remote work culture evolution, sustainable tech, and mental health in the digital age.",
  "For better writing, try the 'Rule of Three' — ideas grouped in threes are more satisfying and memorable. Also, vary your sentence length for rhythm and punch.",
  "The top article right now is about GPT-5's impact on content creation. The key insight: AI accelerates execution, but original perspective still comes entirely from you.",
  "I noticed you're interested in design. The most-read design article this week explores how white space and typography choices drive conversion in SaaS products.",
  "Here's a quick writing tip: Write your first draft without editing. Get the ideas out, then refine. Perfectionism in the first draft is the biggest creativity killer.",
];

function openChatWindow() {
  isOpen = true;
  aiChatWindow.setAttribute('aria-hidden', 'false');
  isMinimized = false;
  aiChatWindow.classList.remove('minimized');
  chatInput.focus();
}

function closeChatWindow() {
  isOpen = false;
  aiChatWindow.setAttribute('aria-hidden', 'true');
}

function toggleMinimize() {
  isMinimized = !isMinimized;
  aiChatWindow.classList.toggle('minimized', isMinimized);
  minimizeChat.title = isMinimized ? 'Expand' : 'Minimize';
}

fabAI.addEventListener('click', () => {
  if (!isOpen) {
    openChatWindow();
  } else if (isMinimized) {
    toggleMinimize();
  } else {
    closeChatWindow();
  }
});

closeChat.addEventListener('click', closeChatWindow);
minimizeChat.addEventListener('click', toggleMinimize);

// Send message
function sendMessage(text) {
  text = text.trim();
  if (!text) return;

  // User message
  const userMsg = document.createElement('div');
  userMsg.className = 'msg-user';
  userMsg.textContent = text;
  chatMessages.appendChild(userMsg);

  // Scroll to bottom
  chatBody.scrollTop = chatBody.scrollHeight;

  // Typing indicator
  const typing = document.createElement('div');
  typing.className = 'typing-indicator';
  typing.innerHTML = '<span></span><span></span><span></span>';
  chatMessages.appendChild(typing);
  chatBody.scrollTop = chatBody.scrollHeight;

  // Simulate AI response
  setTimeout(() => {
    typing.remove();
    const aiMsg = document.createElement('div');
    aiMsg.className = 'msg-ai';
    const randomResponse = aiResponses[Math.floor(Math.random() * aiResponses.length)];
    aiMsg.textContent = randomResponse;
    chatMessages.appendChild(aiMsg);
    chatBody.scrollTop = chatBody.scrollHeight;
  }, 1200 + Math.random() * 600);
}

function sendSuggestion(chip) {
  const text = chip.textContent;
  chip.closest('.chat-suggestions').style.display = 'none';
  sendMessage(text);
}
window.sendSuggestion = sendSuggestion;

chatSend.addEventListener('click', () => {
  sendMessage(chatInput.value);
  chatInput.value = '';
});

chatInput.addEventListener('keydown', (e) => {
  if (e.key === 'Enter' && !e.shiftKey) {
    e.preventDefault();
    sendMessage(chatInput.value);
    chatInput.value = '';
  }
});

// ─── Search bar enter key ───
document.querySelector('.search-input').addEventListener('keydown', (e) => {
  if (e.key === 'Enter') {
    const val = e.target.value.trim();
    if (val) {
      alert(`Searching for: "${val}"\n\n(Connect to backend to implement real search)`);
    }
  }
});
document.querySelector('.search-btn').addEventListener('click', () => {
  const val = document.querySelector('.search-input').value.trim();
  if (val) {
    alert(`Searching for: "${val}"\n\n(Connect to backend to implement real search)`);
  }
});

// ─── Category card micro-interaction ───
document.querySelectorAll('.category-card').forEach(card => {
  card.addEventListener('click', (e) => {
    e.preventDefault();
    const name = card.querySelector('h4').textContent;
    // ripple effect
    const ripple = document.createElement('span');
    const rect = card.getBoundingClientRect();
    const size = Math.max(rect.width, rect.height) * 2;
    ripple.style.cssText = `
      position: absolute;
      width: ${size}px;
      height: ${size}px;
      background: rgba(124,58,237,0.15);
      border-radius: 50%;
      top: ${e.clientY - rect.top - size/2}px;
      left: ${e.clientX - rect.left - size/2}px;
      transform: scale(0);
      animation: rippleAnim 0.5s ease-out forwards;
      pointer-events: none;
      z-index: 10;
    `;
    card.style.overflow = 'hidden';
    card.appendChild(ripple);
    setTimeout(() => ripple.remove(), 600);
  });
});

// Ripple keyframe injection
const rippleStyle = document.createElement('style');
rippleStyle.textContent = `
  @keyframes rippleAnim {
    to { transform: scale(1); opacity: 0; }
  }
`;
document.head.appendChild(rippleStyle);

// ─── Hero CTA pulse on load ───
setTimeout(() => {
  const cta = document.querySelector('.btn-primary.btn-lg');
  if (cta) {
    cta.style.animation = 'heroCtaPulse 0.6s ease';
    setTimeout(() => cta.style.animation = '', 600);
  }
  const ctaStyle = document.createElement('style');
  ctaStyle.textContent = `
    @keyframes heroCtaPulse {
      0% { transform: scale(1); }
      50% { transform: scale(1.06); box-shadow: 0 0 0 8px rgba(124,58,237,0.2); }
      100% { transform: scale(1); }
    }
  `;
  document.head.appendChild(ctaStyle);
}, 1500);

// ─── Close mobile menu on outside click ───
document.addEventListener('click', (e) => {
  if (!navbar.contains(e.target)) {
    mobileMenu.classList.remove('open');
  }
});

// ─── Close chat on outside click (mobile) ───
document.addEventListener('click', (e) => {
  if (isOpen && !isMinimized &&
      !aiChatWindow.contains(e.target) &&
      !fabAI.contains(e.target) &&
      window.innerWidth <= 480) {
    closeChatWindow();
  }
});

</script>
</body>
</html>