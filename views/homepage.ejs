<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Scribix — Write. Read. Learn with AI.</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;500;600;700;800&family=DM+Serif+Display:ital@0;1&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
  <style>
/* ═══════════════════════════════════════════
   SCRIBIX — Premium AI Blogging Platform CSS
   ═══════════════════════════════════════════ */

/* ─── CSS Variables ─── */
:root {
  --bg: #ffffff;
  --bg-alt: #f8f7ff;
  --bg-dark: #0d0d14;
  --bg-card: #ffffff;
  --bg-card-hover: #f3f0ff;
  --border: #e8e4f0;
  --border-hover: #c4b5fd;
  --text-primary: #0f0d1a;
  --text-secondary: #5c5473;
  --text-muted: #9991b0;
  --text-light: #ffffff;
  --accent-purple: #7c3aed;
  --accent-blue: #0ea5e9;
  --accent-light-purple: #a78bfa;
  --accent-light-blue: #38bdf8;
  --gradient: linear-gradient(135deg, #7c3aed, #0ea5e9);
  --gradient-soft: linear-gradient(135deg, #a78bfa22, #38bdf822);
  --gradient-text: linear-gradient(135deg, #a78bfa, #38bdf8);
  --shadow-sm: 0 1px 3px rgba(124,58,237,0.07), 0 1px 2px rgba(0,0,0,0.04);
  --shadow-md: 0 4px 20px rgba(124,58,237,0.1), 0 2px 8px rgba(0,0,0,0.06);
  --shadow-lg: 0 20px 60px rgba(124,58,237,0.15), 0 8px 24px rgba(0,0,0,0.08);
  --shadow-glow: 0 0 40px rgba(167,139,250,0.3);
  --radius-sm: 10px;
  --radius-md: 16px;
  --radius-lg: 24px;
  --radius-xl: 32px;
  --transition: 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  --font-display: 'DM Serif Display', Georgia, serif;
  --font-body: 'Sora', system-ui, sans-serif;
  --font-mono: 'JetBrains Mono', monospace;
}

[data-theme="dark"] {
  --bg: #0d0d14;
  --bg-alt: #12121e;
  --bg-card: #16162a;
  --bg-card-hover: #1e1e35;
  --border: #2a2a45;
  --border-hover: #7c3aed;
  --text-primary: #f0ecff;
  --text-secondary: #a89dc0;
  --text-muted: #6b6385;
  --shadow-sm: 0 1px 3px rgba(0,0,0,0.4);
  --shadow-md: 0 4px 20px rgba(0,0,0,0.4), 0 2px 8px rgba(124,58,237,0.15);
  --shadow-lg: 0 20px 60px rgba(0,0,0,0.5), 0 8px 24px rgba(124,58,237,0.2);
}

/* ─── Reset ─── */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; -webkit-font-smoothing: antialiased; }
body {
  font-family: var(--font-body);
  background: var(--bg);
  color: var(--text-primary);
  transition: background var(--transition), color var(--transition);
  overflow-x: hidden;
}
img { max-width: 100%; display: block; }
a { text-decoration: none; color: inherit; }
ul { list-style: none; }
button { cursor: pointer; font-family: var(--font-body); border: none; background: none; }

/* ─── Container ─── */
.container {
  width: 100%;
  max-width: 1180px;
  margin: 0 auto;
  padding: 0 24px;
}

/* ─── Typography ─── */
.gradient-text {
  background: var(--gradient-text);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

/* ─── Buttons ─── */
.btn {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 10px 20px;
  border-radius: 50px;
  font-size: 14px;
  font-weight: 600;
  font-family: var(--font-body);
  transition: all var(--transition);
  white-space: nowrap;
}
.btn-primary {
  background: var(--gradient);
  color: #fff;
  box-shadow: 0 4px 16px rgba(124,58,237,0.35);
}
.btn-primary:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 28px rgba(124,58,237,0.45);
  filter: brightness(1.08);
}
.btn-primary:active { transform: translateY(0); }
.btn-outline {
  border: 1.5px solid var(--border-hover);
  color: var(--accent-purple);
  background: transparent;
}
.btn-outline:hover {
  background: var(--gradient-soft);
  border-color: var(--accent-light-purple);
  transform: translateY(-2px);
}
.btn-ghost {
  color: var(--text-secondary);
  padding: 8px 16px;
}
.btn-ghost:hover { color: var(--accent-purple); background: var(--gradient-soft); border-radius: 50px; }
.btn-lg { padding: 14px 28px; font-size: 15px; }
.btn-sm { padding: 7px 16px; font-size: 13px; }

/* ═══════════════════════════════════════
   NAVBAR
═══════════════════════════════════════ */
.navbar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 1000;
  background: rgba(255,255,255,0.82);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-bottom: 1px solid var(--border);
  transition: all var(--transition);
}
[data-theme="dark"] .navbar {
  background: rgba(13,13,20,0.85);
}
.navbar.scrolled {
  box-shadow: var(--shadow-md);
}
.nav-inner {
  display: flex;
  align-items: center;
  gap: 40px;
  height: 64px;
  max-width: 1180px;
  margin: 0 auto;
  padding: 0 24px;
}
.logo {
  display: flex;
  align-items: center;
  gap: 10px;
  font-weight: 700;
  font-size: 20px;
  flex-shrink: 0;
}
.logo-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 36px;
  height: 36px;
  background: var(--gradient-soft);
  border-radius: 10px;
  border: 1px solid var(--border-hover);
}
.logo-text {
  background: var(--gradient-text);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}
.nav-links {
  display: flex;
  align-items: center;
  gap: 4px;
  flex: 1;
}
.nav-link {
  padding: 8px 14px;
  border-radius: 8px;
  font-size: 14px;
  font-weight: 500;
  color: var(--text-secondary);
  transition: all var(--transition);
}
.nav-link:hover, .nav-link.active {
  color: var(--accent-purple);
  background: var(--gradient-soft);
}
.nav-actions {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-left: auto;
}
.theme-toggle {
  width: 38px;
  height: 38px;
  border-radius: 10px;
  background: var(--bg-alt);
  border: 1px solid var(--border);
  font-size: 16px;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all var(--transition);
  overflow: hidden;
}
.theme-toggle:hover { border-color: var(--border-hover); transform: scale(1.05); }
.moon { display: none; }
[data-theme="dark"] .sun { display: none; }
[data-theme="dark"] .moon { display: block; }

.hamburger {
  display: none;
  flex-direction: column;
  gap: 5px;
  padding: 6px;
  width: 38px;
  height: 38px;
  align-items: center;
  justify-content: center;
}
.hamburger span {
  width: 20px;
  height: 2px;
  background: var(--text-primary);
  border-radius: 2px;
  transition: all var(--transition);
}
.mobile-menu {
  display: none;
  flex-direction: column;
  padding: 16px 24px;
  border-top: 1px solid var(--border);
  gap: 4px;
  animation: slideDown 0.2s ease;
}
.mobile-menu.open { display: flex; }
.mobile-menu a {
  padding: 10px 14px;
  border-radius: 10px;
  font-size: 15px;
  font-weight: 500;
  color: var(--text-secondary);
  transition: all var(--transition);
}
.mobile-menu a:hover { color: var(--accent-purple); background: var(--gradient-soft); }

@keyframes slideDown {
  from { opacity: 0; transform: translateY(-8px); }
  to { opacity: 1; transform: translateY(0); }
}

/* ═══════════════════════════════════════
   HERO
═══════════════════════════════════════ */
.hero {
  min-height: 100vh;
  display: flex;
  align-items: center;
  position: relative;
  overflow: hidden;
  padding: 120px 0 80px;
}
.hero-bg {
  position: absolute;
  inset: 0;
  z-index: 0;
}
.orb {
  position: absolute;
  border-radius: 50%;
  filter: blur(80px);
  opacity: 0.4;
  animation: drift 8s ease-in-out infinite alternate;
}
.orb-1 {
  width: 500px;
  height: 500px;
  background: radial-gradient(circle, #a78bfa, transparent 70%);
  top: -100px;
  right: -100px;
}
.orb-2 {
  width: 400px;
  height: 400px;
  background: radial-gradient(circle, #38bdf8, transparent 70%);
  bottom: -50px;
  left: -80px;
  animation-delay: -3s;
}
.orb-3 {
  width: 300px;
  height: 300px;
  background: radial-gradient(circle, #6366f1, transparent 70%);
  top: 40%;
  left: 50%;
  animation-delay: -6s;
  opacity: 0.2;
}
@keyframes drift {
  from { transform: translate(0, 0) scale(1); }
  to { transform: translate(20px, 30px) scale(1.05); }
}
.grid-overlay {
  position: absolute;
  inset: 0;
  background-image:
    linear-gradient(var(--border) 1px, transparent 1px),
    linear-gradient(90deg, var(--border) 1px, transparent 1px);
  background-size: 60px 60px;
  opacity: 0.4;
  mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, black, transparent);
}
.hero-content {
  position: relative;
  z-index: 1;
  text-align: center;
  max-width: 820px;
  margin: 0 auto;
}
.hero-badge {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 8px 18px;
  background: var(--gradient-soft);
  border: 1px solid var(--border-hover);
  border-radius: 50px;
  font-size: 13px;
  font-weight: 500;
  color: var(--accent-purple);
  margin-bottom: 32px;
  animation: fadeInUp 0.6s ease both;
}
.badge-dot {
  width: 7px;
  height: 7px;
  background: var(--gradient);
  border-radius: 50%;
  animation: blink 2s ease infinite;
}
@keyframes blink {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.3; }
}
.hero-title {
  font-size: clamp(44px, 7vw, 80px);
  line-height: 1.1;
  margin-bottom: 24px;
  animation: fadeInUp 0.6s 0.1s ease both;
}
.serif-line {
  display: block;
  font-family: var(--font-display);
  font-style: italic;
  color: var(--text-primary);
}
.gradient-line {
  display: block;
  background: var(--gradient-text);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  font-family: var(--font-display);
  font-weight: 400;
}
.hero-sub {
  font-size: clamp(16px, 2vw, 19px);
  color: var(--text-secondary);
  line-height: 1.7;
  max-width: 600px;
  margin: 0 auto 40px;
  animation: fadeInUp 0.6s 0.2s ease both;
}
.hero-cta {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16px;
  flex-wrap: wrap;
  margin-bottom: 48px;
  animation: fadeInUp 0.6s 0.3s ease both;
}
.hero-search {
  animation: fadeInUp 0.6s 0.4s ease both;
  margin-bottom: 56px;
}
.search-wrap {
  display: flex;
  align-items: center;
  gap: 12px;
  background: var(--bg-card);
  border: 1.5px solid var(--border);
  border-radius: 50px;
  padding: 6px 8px 6px 20px;
  max-width: 560px;
  margin: 0 auto 12px;
  box-shadow: var(--shadow-md);
  transition: all var(--transition);
}
.search-wrap:focus-within {
  border-color: var(--border-hover);
  box-shadow: var(--shadow-glow), var(--shadow-md);
}
.search-icon { color: var(--text-muted); flex-shrink: 0; }
.search-input {
  flex: 1;
  border: none;
  outline: none;
  font-size: 15px;
  font-family: var(--font-body);
  background: transparent;
  color: var(--text-primary);
}
.search-input::placeholder { color: var(--text-muted); }
.search-btn {
  background: var(--gradient);
  color: #fff;
  border-radius: 50px;
  padding: 9px 22px;
  font-size: 14px;
  font-weight: 600;
  font-family: var(--font-body);
  transition: all var(--transition);
}
.search-btn:hover { filter: brightness(1.1); }
.search-hint {
  font-size: 13px;
  color: var(--text-muted);
  text-align: center;
}
.search-hint a {
  color: var(--accent-purple);
  font-weight: 500;
  padding: 2px 6px;
  border-radius: 4px;
  transition: background var(--transition);
}
.search-hint a:hover { background: var(--gradient-soft); }

/* Hero AI Badge */
.hero-ai-badge {
  position: absolute;
  right: 80px;
  top: 50%;
  transform: translateY(-80px);
  animation: floatBadge 4s ease-in-out infinite, fadeInUp 0.8s 0.5s ease both;
}
@keyframes floatBadge {
  0%, 100% { transform: translateY(-80px); }
  50% { transform: translateY(-96px); }
}
.ai-glow-ring {
  position: absolute;
  inset: -12px;
  border-radius: 50%;
  background: conic-gradient(from 0deg, #a78bfa, #38bdf8, #a78bfa);
  animation: spin 4s linear infinite;
  opacity: 0.5;
  filter: blur(4px);
}
@keyframes spin { to { transform: rotate(360deg); } }
.ai-inner {
  position: relative;
  width: 72px;
  height: 72px;
  background: var(--bg);
  border-radius: 50%;
  border: 2px solid var(--border-hover);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 2px;
  box-shadow: var(--shadow-lg);
}
.ai-inner span {
  font-size: 11px;
  font-weight: 700;
  background: var(--gradient-text);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  font-family: var(--font-mono);
}

/* Hero Stats */
.hero-stats {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 32px;
  animation: fadeInUp 0.6s 0.5s ease both;
}
.stat {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 2px;
}
.stat strong {
  font-size: 26px;
  font-weight: 700;
  background: var(--gradient-text);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}
.stat span {
  font-size: 13px;
  color: var(--text-muted);
  font-weight: 500;
}
.stat-divider {
  width: 1px;
  height: 32px;
  background: var(--border);
}

@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(20px); }
  to { opacity: 1; transform: translateY(0); }
}

/* ═══════════════════════════════════════
   SECTIONS
═══════════════════════════════════════ */
.section {
  padding: 96px 0;
}
.section-alt {
  background: var(--bg-alt);
}
.section-dark {
  background: var(--bg-dark);
  position: relative;
  overflow: hidden;
}
[data-theme="dark"] .section-dark {
  background: #08080f;
}
.section-header {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  margin-bottom: 48px;
  gap: 20px;
}
.section-header.centered {
  flex-direction: column;
  align-items: center;
  text-align: center;
}
.section-label {
  font-size: 13px;
  font-weight: 600;
  color: var(--accent-purple);
  text-transform: uppercase;
  letter-spacing: 1.5px;
  margin-bottom: 8px;
}
.section-title {
  font-family: var(--font-display);
  font-size: clamp(28px, 4vw, 40px);
  font-weight: 400;
  color: var(--text-primary);
  line-height: 1.2;
}
.section-title.light { color: #fff; }
.section-desc {
  font-size: 16px;
  color: var(--text-secondary);
  max-width: 560px;
  line-height: 1.7;
  margin-top: 12px;
}
.section-desc.light { color: #a89dc0; }

/* ═══════════════════════════════════════
   ARTICLES GRID
═══════════════════════════════════════ */
.articles-grid {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  grid-template-rows: auto auto;
  gap: 20px;
}
.article-featured {
  grid-column: 1;
  grid-row: 1 / 3;
}
.article-card {
  background: var(--bg-card);
  border-radius: var(--radius-md);
  border: 1px solid var(--border);
  overflow: hidden;
  transition: all var(--transition);
  display: flex;
  flex-direction: column;
}
.article-card:hover {
  transform: translateY(-4px);
  border-color: var(--border-hover);
  box-shadow: var(--shadow-lg);
}
.card-img {
  position: relative;
  overflow: hidden;
  aspect-ratio: 16/9;
}
.article-featured .card-img {
  aspect-ratio: 4/3;
}
.small-img { aspect-ratio: 16/7; }
.card-img img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.5s ease;
}
.article-card:hover .card-img img { transform: scale(1.04); }
.card-tag {
  position: absolute;
  top: 12px;
  left: 12px;
  background: rgba(124,58,237,0.85);
  color: #fff;
  font-size: 11px;
  font-weight: 600;
  padding: 4px 10px;
  border-radius: 50px;
  backdrop-filter: blur(4px);
}
.card-body {
  padding: 20px;
  display: flex;
  flex-direction: column;
  gap: 10px;
  flex: 1;
}
.card-meta {
  display: flex;
  align-items: center;
  gap: 7px;
  font-size: 12.5px;
  color: var(--text-muted);
}
.avatar-xs {
  width: 22px;
  height: 22px;
  border-radius: 50%;
  object-fit: cover;
}
.author-name { font-weight: 600; color: var(--text-secondary); }
.dot { opacity: 0.5; }
.read-time, .date { font-size: 12px; }
.card-title {
  font-size: 16px;
  font-weight: 700;
  line-height: 1.4;
  color: var(--text-primary);
  transition: color var(--transition);
}
.article-featured .card-title { font-size: 20px; font-family: var(--font-display); }
.article-card:hover .card-title { color: var(--accent-purple); }
.card-excerpt {
  font-size: 14px;
  color: var(--text-secondary);
  line-height: 1.6;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.card-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: auto;
  padding-top: 12px;
  border-top: 1px solid var(--border);
}
.reactions {
  display: flex;
  gap: 12px;
  font-size: 13px;
  color: var(--text-muted);
}
.save-btn {
  width: 32px;
  height: 32px;
  border-radius: 8px;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--text-muted);
  border: 1px solid var(--border);
  transition: all var(--transition);
}
.save-btn:hover {
  color: var(--accent-purple);
  border-color: var(--border-hover);
  background: var(--gradient-soft);
}

/* ═══════════════════════════════════════
   AUTHORS
═══════════════════════════════════════ */
.authors-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20px;
}
.author-card {
  background: var(--bg-card);
  border-radius: var(--radius-md);
  border: 1px solid var(--border);
  overflow: hidden;
  transition: all var(--transition);
}
.author-card:hover {
  transform: translateY(-4px);
  border-color: var(--border-hover);
  box-shadow: var(--shadow-lg);
}
.author-cover {
  height: 72px;
}
.author-body {
  padding: 0 20px 24px;
}
.author-avatar-wrap {
  position: relative;
  margin-top: -28px;
  margin-bottom: 12px;
  width: fit-content;
}
.author-avatar {
  width: 56px;
  height: 56px;
  border-radius: 50%;
  border: 3px solid var(--bg-card);
  object-fit: cover;
}
.verified-badge {
  position: absolute;
  bottom: 0;
  right: -2px;
  width: 18px;
  height: 18px;
  background: #7c3aed;
  color: white;
  border-radius: 50%;
  font-size: 9px;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2px solid var(--bg-card);
}
.author-name {
  font-size: 16px;
  font-weight: 700;
  color: var(--text-primary);
}
.author-handle {
  font-size: 13px;
  color: var(--accent-purple);
  margin: 2px 0 10px;
}
.author-bio {
  font-size: 13px;
  color: var(--text-secondary);
  line-height: 1.5;
  margin-bottom: 16px;
}
.author-stats {
  display: flex;
  gap: 16px;
  margin-bottom: 16px;
  padding-top: 12px;
  border-top: 1px solid var(--border);
}
.author-stats div {
  display: flex;
  flex-direction: column;
  gap: 2px;
}
.author-stats strong {
  font-size: 15px;
  font-weight: 700;
  color: var(--text-primary);
}
.author-stats span {
  font-size: 11px;
  color: var(--text-muted);
}
