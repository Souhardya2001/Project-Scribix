<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>How GPT-5 is Quietly Rewriting the Rules of Content Creation — Scribix</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=Sora:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
/* ════════════════════════════════════════════════
   SCRIBIX ARTICLE PAGE — Premium Editorial CSS
════════════════════════════════════════════════ */
:root {
  --bg:           #fdfcf9;
  --bg-alt:       #f7f5f0;
  --bg-card:      #ffffff;
  --bg-sidebar:   #faf9f6;
  --border:       #ede9e0;
  --border-hover: #c4b5fd;
  --text-primary: #1a1612;
  --text-body:    #2d2925;
  --text-secondary:#6b6258;
  --text-muted:   #a09488;
  --accent:       #7c3aed;
  --accent-2:     #0ea5e9;
  --accent-warm:  #f59e0b;
  --gradient:     linear-gradient(135deg,#7c3aed,#0ea5e9);
  --gradient-warm:linear-gradient(135deg,#f59e0b,#ef4444);
  --gradient-soft:linear-gradient(135deg,#a78bfa18,#38bdf812);
  --gradient-text:linear-gradient(135deg,#a78bfa,#38bdf8);
  --shadow-xs:    0 1px 3px rgba(26,22,18,.06);
  --shadow-sm:    0 2px 8px rgba(26,22,18,.08);
  --shadow-md:    0 8px 30px rgba(26,22,18,.1);
  --shadow-lg:    0 20px 60px rgba(26,22,18,.13);
  --shadow-glow:  0 0 30px rgba(124,58,237,.22);
  --radius-sm:    8px;
  --radius-md:    14px;
  --radius-lg:    20px;
  --font-serif:   'Lora', Georgia, serif;
  --font-sans:    'Sora', system-ui, sans-serif;
  --font-mono:    'JetBrains Mono', monospace;
  --ease:         cubic-bezier(.4,0,.2,1);
  --spring:       cubic-bezier(.34,1.56,.64,1);
  --t:            .22s;
  --content-w:    680px;
}
[data-theme="dark"] {
  --bg:           #0f0d0a;
  --bg-alt:       #161410;
  --bg-card:      #1c1915;
  --bg-sidebar:   #161410;
  --border:       #2a2620;
  --border-hover: #7c3aed;
  --text-primary: #f0ece6;
  --text-body:    #d4cfc8;
  --text-secondary:#9b9188;
  --text-muted:   #6b6258;
  --shadow-md:    0 8px 30px rgba(0,0,0,.4);
  --shadow-lg:    0 20px 60px rgba(0,0,0,.5);
}

*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
html{scroll-behavior:smooth;-webkit-font-smoothing:antialiased;}
body{
  font-family:var(--font-sans);
  background:var(--bg);
  color:var(--text-primary);
  transition:background var(--t) var(--ease),color var(--t) var(--ease);
  overflow-x:hidden;
}
img{max-width:100%;display:block;}
a{text-decoration:none;color:inherit;}
button{cursor:pointer;font-family:var(--font-sans);border:none;background:none;}

/* ── Reading progress bar ── */
#progress-bar {
  position:fixed;top:0;left:0;z-index:2000;
  height:3px;width:0%;
  background:var(--gradient);
  transition:width .1s linear;
  border-radius:0 2px 2px 0;
}

/* ════════════════
   NAVBAR
════════════════ */
.navbar {
  position:fixed;top:3px;left:0;right:0;z-index:1000;
  background:rgba(253,252,249,.88);
  backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);
  border-bottom:1px solid var(--border);
  transition:all var(--t) var(--ease);
}
[data-theme="dark"] .navbar{background:rgba(15,13,10,.88);}
.navbar.scrolled{box-shadow:var(--shadow-sm);}
.nav-inner{
  max-width:1260px;margin:0 auto;padding:0 24px;
  height:60px;display:flex;align-items:center;gap:24px;
}
.logo{display:flex;align-items:center;gap:9px;flex-shrink:0;}
.logo-icon{
  width:33px;height:33px;
  background:linear-gradient(135deg,#a78bfa18,#38bdf818);
  border:1px solid var(--border-hover);border-radius:9px;
  display:flex;align-items:center;justify-content:center;
}
.logo-text{
  font-size:19px;font-weight:700;
  background:var(--gradient-text);
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
}
.nav-center{flex:1;display:flex;justify-content:center;}
.nav-breadcrumb{
  display:flex;align-items:center;gap:6px;
  font-size:13px;color:var(--text-muted);
}
.nav-breadcrumb span{color:var(--border);}
.nav-breadcrumb a{color:var(--text-secondary);font-weight:500;transition:color var(--t);}
.nav-breadcrumb a:hover{color:var(--accent);}
.nav-right{display:flex;align-items:center;gap:10px;margin-left:auto;}
.nav-btn{
  display:flex;align-items:center;gap:7px;
  padding:8px 16px;border-radius:50px;
  font-size:13px;font-weight:600;
  transition:all var(--t) var(--ease);
}
.nav-btn-ghost{color:var(--text-secondary);}
.nav-btn-ghost:hover{background:var(--bg-alt);color:var(--text-primary);}
.nav-btn-primary{
  background:var(--gradient);color:#fff;
  box-shadow:0 3px 12px rgba(124,58,237,.3);
}
.nav-btn-primary:hover{transform:translateY(-1px);box-shadow:0 5px 18px rgba(124,58,237,.4);}
.theme-toggle{
  width:34px;height:34px;border-radius:9px;
  background:var(--bg-alt);border:1px solid var(--border);
  display:flex;align-items:center;justify-content:center;
  font-size:15px;transition:all var(--t) var(--ease);
}
.theme-toggle:hover{border-color:var(--border-hover);}
.moon-i{display:none;}
[data-theme="dark"] .sun-i{display:none;}
[data-theme="dark"] .moon-i{display:block;}

/* ════════════════
   LAYOUT
════════════════ */
.page-wrap{
  max-width:1260px;margin:0 auto;
  padding:88px 24px 80px;
  display:grid;
  grid-template-columns:1fr 320px;
  gap:48px;
  align-items:start;
}

/* ════════════════
   ARTICLE MAIN
════════════════ */
.article-main{}

/* category tag + title */
.article-tag{
  display:inline-flex;align-items:center;gap:7px;
  padding:5px 14px;
  background:var(--gradient-soft);
  border:1px solid var(--border-hover);
  border-radius:50px;
  font-size:12px;font-weight:600;letter-spacing:.8px;
  color:var(--accent);text-transform:uppercase;
  margin-bottom:22px;
}
.tag-dot{width:5px;height:5px;background:var(--accent);border-radius:50%;}

.article-title{
  font-family:var(--font-serif);
  font-size:clamp(28px,4vw,46px);
  font-weight:700;line-height:1.18;
  color:var(--text-primary);
  margin-bottom:20px;
  letter-spacing:-.3px;
}
.article-subtitle{
  font-size:clamp(16px,2vw,20px);
  color:var(--text-secondary);
  line-height:1.65;
  font-family:var(--font-serif);
  font-style:italic;
  margin-bottom:32px;
  border-left:3px solid var(--accent);
  padding-left:18px;
}

/* author row */
.author-row{
  display:flex;align-items:center;justify-content:space-between;
  flex-wrap:wrap;gap:16px;
  padding:20px 0;
  border-top:1px solid var(--border);
  border-bottom:1px solid var(--border);
  margin-bottom:36px;
}
.author-left{display:flex;align-items:center;gap:13px;}
.author-avatar-wrap{position:relative;}
.author-avatar{
  width:48px;height:48px;border-radius:50%;
  border:2px solid var(--border-hover);
  object-fit:cover;
}
.author-verified{
  position:absolute;bottom:-1px;right:-1px;
  width:17px;height:17px;border-radius:50%;
  background:var(--accent);color:#fff;
  font-size:9px;font-weight:700;
  display:flex;align-items:center;justify-content:center;
  border:2px solid var(--bg);
}
.author-info{display:flex;flex-direction:column;gap:3px;}
.author-name{font-size:15px;font-weight:700;color:var(--text-primary);}
.author-handle{font-size:12.5px;color:var(--accent);}
.author-meta{
  display:flex;align-items:center;gap:10px;
  font-size:12.5px;color:var(--text-muted);flex-wrap:wrap;
}
.meta-dot{width:3px;height:3px;background:var(--border);border-radius:50%;}
.follow-btn{
  padding:7px 18px;border-radius:50px;
  font-size:13px;font-weight:600;
  border:1.5px solid var(--border-hover);
  color:var(--accent);
  transition:all var(--t) var(--ease);background:transparent;
}
.follow-btn:hover{background:var(--gradient-soft);}
.follow-btn.following{background:var(--gradient);color:#fff;border-color:transparent;}

/* cover image */
.cover-wrap{
  margin-bottom:40px;
  border-radius:var(--radius-lg);
  overflow:hidden;
  position:relative;
  box-shadow:var(--shadow-lg);
}
.cover-img{
  width:100%;aspect-ratio:16/8;
  object-fit:cover;
  transition:transform .6s var(--ease);
}
.cover-wrap:hover .cover-img{transform:scale(1.02);}
.cover-caption{
  position:absolute;bottom:0;left:0;right:0;
  padding:16px 22px;
  background:linear-gradient(to top,rgba(0,0,0,.65),transparent);
  font-size:12.5px;color:rgba(255,255,255,.75);
  font-style:italic;
}

/* ── article body ── */
.article-body{
  font-family:var(--font-serif);
  font-size:clamp(17px,2vw,19.5px);
  line-height:1.82;
  color:var(--text-body);
  max-width:var(--content-w);
}
.article-body p{margin-bottom:1.55em;}
.article-body h2{
  font-size:clamp(20px,2.5vw,26px);
  font-weight:700;line-height:1.3;
  color:var(--text-primary);
  margin:2em 0 .7em;
  letter-spacing:-.2px;
}
.article-body h3{
  font-size:clamp(17px,2vw,21px);
  font-weight:600;line-height:1.35;
  color:var(--text-primary);
  margin:1.6em 0 .6em;
}
.article-body blockquote{
  margin:2em 0;
  padding:22px 26px;
  border-left:4px solid var(--accent);
  background:linear-gradient(135deg,rgba(124,58,237,.05),rgba(14,165,233,.04));
  border-radius:0 var(--radius-md) var(--radius-md) 0;
  font-style:italic;
  font-size:1.08em;
  color:var(--text-primary);
}
.article-body blockquote cite{
  display:block;margin-top:12px;
  font-size:.8em;font-style:normal;
  font-weight:600;color:var(--text-muted);
  font-family:var(--font-sans);
}
.article-body strong{color:var(--text-primary);font-weight:700;}
.article-body em{color:var(--text-primary);}
.article-body a{
  color:var(--accent);
  border-bottom:1px solid rgba(124,58,237,.3);
  transition:border-color var(--t) var(--ease);
}
.article-body a:hover{border-color:var(--accent);}
.article-body .callout{
  display:flex;gap:14px;
  padding:18px 22px;
  border-radius:var(--radius-md);
  background:var(--bg-alt);
  border:1px solid var(--border);
  margin:1.8em 0;
}
.callout-icon{font-size:22px;flex-shrink:0;margin-top:2px;}
.callout-text{font-size:.92em;font-family:var(--font-sans);color:var(--text-secondary);line-height:1.65;}
.callout-text strong{color:var(--text-primary);font-weight:700;display:block;margin-bottom:4px;}
.article-body .highlight{
  background:linear-gradient(135deg,rgba(245,158,11,.18),rgba(239,68,68,.1));
  border-radius:4px;padding:0 4px;
  color:var(--text-primary);
}
/* inline code */
.article-body code{
  font-family:var(--font-mono);
  font-size:.85em;
  background:var(--bg-alt);
  border:1px solid var(--border);
  border-radius:5px;
  padding:2px 7px;
  color:var(--accent);
}

/* ── reaction bar ── */
.reaction-bar{
  display:flex;align-items:center;gap:12px;
  padding:24px 0;
  border-top:1px solid var(--border);
  border-bottom:1px solid var(--border);
  margin:44px 0 48px;
  flex-wrap:wrap;
}
.react-btn{
  display:flex;align-items:center;gap:7px;
  padding:9px 18px;
  border-radius:50px;
  font-size:13.5px;font-weight:600;
  border:1.5px solid var(--border);
  color:var(--text-secondary);
  background:var(--bg-card);
  transition:all var(--t) var(--ease);
}
.react-btn:hover{border-color:var(--border-hover);color:var(--accent);background:var(--gradient-soft);}
.react-btn.active-like{background:linear-gradient(135deg,#fef3c7,#fde68a);border-color:#f59e0b;color:#92400e;}
.react-btn.active-dislike{background:linear-gradient(135deg,#fee2e2,#fecaca);border-color:#f87171;color:#991b1b;}
.react-btn.active-bookmark{background:var(--gradient-soft);border-color:var(--border-hover);color:var(--accent);}
.react-count{font-size:13px;color:var(--text-muted);}
.share-group{display:flex;align-items:center;gap:8px;margin-left:auto;}
.share-btn{
  width:36px;height:36px;border-radius:50%;
  display:flex;align-items:center;justify-content:center;
  border:1.5px solid var(--border);
  color:var(--text-muted);
  background:var(--bg-card);
  font-size:14px;font-weight:700;
  transition:all var(--t) var(--ease);
}
.share-btn:hover{border-color:var(--border-hover);color:var(--accent);transform:scale(1.1);}

/* ── tags section ── */
.article-tags{
  display:flex;flex-wrap:wrap;gap:8px;margin-bottom:52px;
}
.atag{
  padding:6px 14px;border-radius:50px;
  font-size:13px;font-weight:500;font-family:var(--font-sans);
  background:var(--bg-alt);border:1px solid var(--border);
  color:var(--text-secondary);
  transition:all var(--t) var(--ease);
}
.atag:hover{border-color:var(--border-hover);color:var(--accent);background:var(--gradient-soft);}

/* ════════════════
   COMMENTS
════════════════ */
.comments-section{max-width:var(--content-w);}
.section-title-row{
  display:flex;align-items:center;justify-content:space-between;
  margin-bottom:28px;
}
.section-title{
  font-size:22px;font-weight:700;
  color:var(--text-primary);font-family:var(--font-sans);
}
.comment-count{
  font-size:13px;font-weight:600;
  color:var(--text-muted);
  padding:4px 12px;border-radius:50px;
  background:var(--bg-alt);border:1px solid var(--border);
}

/* compose */
.comment-compose{
  display:flex;gap:12px;margin-bottom:32px;
  padding:20px;
  border-radius:var(--radius-md);
  background:var(--bg-card);
  border:1px solid var(--border);
  transition:border-color var(--t) var(--ease);
  box-shadow:var(--shadow-xs);
}
.comment-compose:focus-within{border-color:var(--border-hover);box-shadow:0 0 0 3px rgba(124,58,237,.1);}
.compose-av{width:36px;height:36px;border-radius:50%;object-fit:cover;flex-shrink:0;}
.compose-right{flex:1;display:flex;flex-direction:column;gap:10px;}
.compose-input{
  width:100%;border:none;outline:none;resize:none;
  font-size:14.5px;line-height:1.65;
  background:transparent;color:var(--text-primary);
  font-family:var(--font-sans);min-height:60px;
}
.compose-input::placeholder{color:var(--text-muted);}
.compose-footer{display:flex;justify-content:flex-end;}
.post-btn{
  padding:8px 20px;border-radius:50px;
  font-size:13px;font-weight:700;font-family:var(--font-sans);
  background:var(--gradient);color:#fff;
  box-shadow:0 3px 12px rgba(124,58,237,.3);
  transition:all var(--t) var(--ease);
}
.post-btn:hover{transform:translateY(-1px);box-shadow:0 5px 18px rgba(124,58,237,.4);}

/* comment cards */
.comment-list{display:flex;flex-direction:column;gap:0;}
.comment-item{
  padding:24px 0;
  border-bottom:1px solid var(--border);
  animation:commentIn .4s var(--ease) both;
}
@keyframes commentIn{from{opacity:0;transform:translateY(12px);}to{opacity:1;transform:translateY(0);}}
.comment-header{display:flex;align-items:flex-start;gap:12px;margin-bottom:12px;}
.comment-av{width:38px;height:38px;border-radius:50%;object-fit:cover;flex-shrink:0;}
.comment-meta{flex:1;}
.comment-name{font-size:14px;font-weight:700;color:var(--text-primary);}
.comment-time{font-size:12px;color:var(--text-muted);margin-top:2px;}
.comment-badge{
  font-size:10.5px;font-weight:600;padding:2px 9px;border-radius:50px;
  background:var(--gradient-soft);border:1px solid var(--border-hover);
  color:var(--accent);margin-left:7px;
}
.comment-text{
  font-size:14.5px;line-height:1.72;
  color:var(--text-body);
  margin-bottom:12px;font-family:var(--font-serif);
}
.comment-actions{display:flex;align-items:center;gap:14px;}
.cact-btn{
  display:flex;align-items:center;gap:5px;
  font-size:12.5px;font-weight:600;
  color:var(--text-muted);
  transition:color var(--t) var(--ease);
}
.cact-btn:hover{color:var(--accent);}
.reply-form{
  margin-top:16px;margin-left:50px;
  padding:14px;border-radius:var(--radius-sm);
  background:var(--bg-alt);border:1px solid var(--border);display:none;
}
.reply-form.open{display:block;}
.reply-input{
  width:100%;border:none;outline:none;resize:none;
  font-size:13.5px;line-height:1.6;background:transparent;
  color:var(--text-primary);font-family:var(--font-sans);
  min-height:48px;
}
.reply-input::placeholder{color:var(--text-muted);}
.reply-footer{display:flex;justify-content:flex-end;gap:8px;margin-top:8px;}
.reply-cancel{padding:6px 14px;border-radius:50px;font-size:12.5px;font-weight:600;color:var(--text-muted);}
.reply-cancel:hover{color:var(--text-primary);}
.reply-post{padding:6px 16px;border-radius:50px;font-size:12.5px;font-weight:700;font-family:var(--font-sans);background:var(--gradient);color:#fff;}

/* nested reply */
.comment-replies{margin-left:50px;margin-top:16px;display:flex;flex-direction:column;gap:16px;}
.comment-reply{
  padding:16px;border-radius:var(--radius-sm);
  background:var(--bg-alt);border:1px solid var(--border);
}
.reply-header{display:flex;align-items:center;gap:9px;margin-bottom:8px;}
.reply-av{width:28px;height:28px;border-radius:50%;object-fit:cover;}
.reply-name{font-size:13px;font-weight:700;color:var(--text-primary);}
.reply-time{font-size:11px;color:var(--text-muted);}
.reply-text{font-size:13.5px;line-height:1.65;color:var(--text-body);font-family:var(--font-serif);}

/* ════════════════
   SIDEBAR
════════════════ */
.sidebar{
  position:sticky;top:80px;
  display:flex;flex-direction:column;
  gap:24px;
}
.sidebar-card{
  background:var(--bg-card);
  border:1px solid var(--border);
  border-radius:var(--radius-md);
  overflow:hidden;
  transition:all var(--t) var(--ease);
  box-shadow:var(--shadow-xs);
}
.sidebar-card:hover{border-color:var(--border-hover);box-shadow:var(--shadow-sm);}
.sidebar-card-head{
  padding:18px 20px 14px;
  border-bottom:1px solid var(--border);
  display:flex;align-items:center;justify-content:space-between;
}
.sidebar-card-title{font-size:13.5px;font-weight:700;color:var(--text-primary);}
.sidebar-card-body{padding:16px 20px 20px;}

/* TOC */
.toc-list{display:flex;flex-direction:column;gap:3px;}
.toc-item{
  display:flex;align-items:flex-start;gap:10px;
  padding:7px 10px;border-radius:var(--radius-sm);
  font-size:13px;font-weight:500;color:var(--text-secondary);
  cursor:pointer;
  transition:all var(--t) var(--ease);
  border-left:2px solid transparent;
}
.toc-item:hover{color:var(--accent);background:var(--gradient-soft);border-left-color:var(--accent);}
.toc-item.active{color:var(--accent);background:var(--gradient-soft);border-left-color:var(--accent);}
.toc-num{
  font-size:11px;font-family:var(--font-mono);
  color:var(--text-muted);margin-top:2px;flex-shrink:0;
  font-weight:500;
}

/* author card */
.author-card-body{text-align:center;padding:22px 20px;}
.ac-avatar{width:64px;height:64px;border-radius:50%;border:2px solid var(--border-hover);object-fit:cover;margin:0 auto 10px;}
.ac-name{font-size:15px;font-weight:700;color:var(--text-primary);margin-bottom:3px;}
.ac-handle{font-size:12.5px;color:var(--accent);margin-bottom:10px;}
.ac-bio{font-size:13px;color:var(--text-secondary);line-height:1.6;margin-bottom:14px;}
.ac-stats{display:flex;justify-content:center;gap:20px;margin-bottom:16px;padding-top:14px;border-top:1px solid var(--border);}
.ac-stat strong{display:block;font-size:16px;font-weight:700;color:var(--text-primary);}
.ac-stat span{font-size:11px;color:var(--text-muted);}
.ac-follow{
  width:100%;padding:9px;border-radius:50px;
  font-size:13px;font-weight:700;font-family:var(--font-sans);
