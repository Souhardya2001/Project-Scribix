<script>
/* ── Theme ── */
const themeToggle = document.getElementById('themeToggle');
const html = document.documentElement;
html.setAttribute('data-theme', localStorage.getItem('scribix-theme') || 'light');
themeToggle.addEventListener('click', () => {
  const next = html.getAttribute('data-theme') === 'light' ? 'dark' : 'light';
  html.setAttribute('data-theme', next);
  localStorage.setItem('scribix-theme', next);
});

/* ── Navbar scroll ── */
window.addEventListener('scroll', () => {
  document.getElementById('navbar').classList.toggle('scrolled', window.scrollY > 40);
});

/* ── Reading progress ── */
function updateProgress() {
  const body = document.getElementById('articleBody');
  const rect = body.getBoundingClientRect();
  const totalH = body.offsetHeight;
  const scrolled = Math.max(0, -rect.top + window.innerHeight * 0.1);
  const pct = Math.min(100, Math.round((scrolled / totalH) * 100));
  document.getElementById('progress-bar').style.width = pct + '%';
  document.getElementById('sidebarFill').style.width = pct + '%';
  document.getElementById('progressPct').textContent = pct + '%';
  updateTOC();
}
window.addEventListener('scroll', updateProgress, { passive: true });

/* ── TOC active state ── */
function updateTOC() {
  const headings = ['h2-threshold','h2-creators','h3-voice','h2-publishers','h2-readers','h2-future'];
  let active = null;
  headings.forEach(id => {
    const el = document.getElementById(id);
    if (el) {
      const top = el.getBoundingClientRect().top;
      if (top < 120) active = id;
    }
  });
  document.querySelectorAll('.toc-item').forEach(item => {
    item.classList.toggle('active', item.dataset.target === active);
  });
}
document.querySelectorAll('.toc-item').forEach(item => {
  item.addEventListener('click', () => {
    const el = document.getElementById(item.dataset.target);
    if (el) el.scrollIntoView({ behavior:'smooth', block:'start' });
  });
});

/* ── Reactions ── */
let liked = false, disliked = false, bookmarked = false;
let likeCount = 4200;
const likeBtn = document.getElementById('likeBtn');
const dislikeBtn = document.getElementById('dislikeBtn');
const bookmarkBtn = document.getElementById('bookmarkBtn');
const likeCountEl = document.getElementById('likeCount');

function fmtNum(n) { return n >= 1000 ? (n/1000).toFixed(1) + 'K' : n; }

likeBtn.addEventListener('click', () => {
  liked = !liked;
  if (liked && disliked) { disliked = false; dislikeBtn.classList.remove('active-dislike'); }
  likeCount += liked ? 1 : -1;
  likeCountEl.textContent = fmtNum(likeCount);
  likeBtn.classList.toggle('active-like', liked);
  likeBtn.style.transform = 'scale(1.08)';
  setTimeout(() => likeBtn.style.transform = '', 200);
});
dislikeBtn.addEventListener('click', () => {
  disliked = !disliked;
  if (disliked && liked) { liked = false; likeCount--; likeCountEl.textContent = fmtNum(likeCount); likeBtn.classList.remove('active-like'); }
  dislikeBtn.classList.toggle('active-dislike', disliked);
});
bookmarkBtn.addEventListener('click', () => {
  bookmarked = !bookmarked;
  bookmarkBtn.classList.toggle('active-bookmark', bookmarked);
  bookmarkBtn.style.transform = 'scale(1.1)';
  setTimeout(() => bookmarkBtn.style.transform = '', 200);
  showToast(bookmarked ? '🔖 Saved to bookmarks' : 'Removed from bookmarks');
});

/* copy link */
document.getElementById('copyLinkBtn').addEventListener('click', () => {
  navigator.clipboard.writeText(window.location.href).catch(() => {});
  showToast('🔗 Link copied!');
});

/* ── Follow buttons ── */
function setupFollow(btnId) {
  const btn = document.getElementById(btnId);
  if (!btn) return;
  btn.addEventListener('click', () => {
    const following = btn.classList.toggle('following');
    btn.textContent = following ? '✓ Following' : (btnId === 'followAuthorBtn' ? '+ Follow' : 'Follow Aria');
    if (following) showToast('✓ You\'re now following Aria Chen');
  });
}
setupFollow('followAuthorBtn');
setupFollow('sidebarFollowBtn');
document.getElementById('sidebarFollowBtn').addEventListener('click', () => {
  const mainBtn = document.getElementById('followAuthorBtn');
  const sideBtn = document.getElementById('sidebarFollowBtn');
  const f = sideBtn.classList.contains('following');
  mainBtn.textContent = f ? '✓ Following' : '+ Follow';
  mainBtn.classList.toggle('following', f);
});

/* ── Comments ── */
document.querySelectorAll('.reply-trigger').forEach(btn => {
  btn.addEventListener('click', () => {
    const target = btn.dataset.reply || 'rf-0';
    const form = document.getElementById(target);
    if (!form) return;
    const open = form.classList.toggle('open');
    if (open) form.querySelector('.reply-input').focus();
  });
});
function closeReply(id) {
  const el = document.getElementById(id);
  if (el) el.classList.remove('open');
}
window.closeReply = closeReply;

document.getElementById('postCommentBtn').addEventListener('click', () => {
  const inp = document.getElementById('composeInput');
  const text = inp.value.trim();
  if (!text) return;
  const item = document.createElement('div');
  item.className = 'comment-item';
  item.style.animationDelay = '0s';
  item.innerHTML = `
    <div class="comment-header">
      <img src="https://i.pravatar.cc/76?img=33" class="comment-av" alt="You"/>
      <div class="comment-meta">
        <div><span class="comment-name">You</span><span class="comment-badge">Reader</span></div>
        <div class="comment-time">Just now</div>
      </div>
    </div>
    <p class="comment-text">${text.replace(/</g,'&lt;')}</p>
    <div class="comment-actions">
      <button class="cact-btn"><svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M14 9V5a3 3 0 00-3-3l-4 9v11h11.28a2 2 0 002-1.7l1.38-9a2 2 0 00-2-2.3H14z"/></svg> 0</button>
      <button class="cact-btn">↩ Reply</button>
    </div>`;
  const list = document.getElementById('commentList');
  list.insertBefore(item, list.firstChild);
  inp.value = '';
  showToast('💬 Comment posted!');
});

/* ── Toast ── */
let toastTimer;
function showToast(msg) {
  let t = document.getElementById('_toast');
  if (!t) {
    t = document.createElement('div');
    t.id = '_toast';
    t.style.cssText = 'position:fixed;bottom:24px;left:50%;transform:translateX(-50%) translateY(60px);background:#1a1612;color:#fff;padding:11px 22px;border-radius:50px;font-size:13px;font-weight:600;box-shadow:0 8px 28px rgba(0,0,0,.3);transition:transform .3s cubic-bezier(.34,1.56,.64,1),opacity .2s ease;opacity:0;z-index:9999;white-space:nowrap;border:1px solid rgba(255,255,255,.1);font-family:var(--font-sans);';
    document.body.appendChild(t);
  }
  clearTimeout(toastTimer);
  t.textContent = msg;
  t.style.transform = 'translateX(-50%) translateY(0)';
  t.style.opacity = '1';
  toastTimer = setTimeout(() => {
    t.style.transform = 'translateX(-50%) translateY(60px)';
    t.style.opacity = '0';
  }, 3000);
}

/* ══════ AI PANEL ══════ */
const fabAI = document.getElementById('fabAI');
const aiPanel = document.getElementById('aiPanel');
const closeAI = document.getElementById('closeAI');
const minimizeAI = document.getElementById('minimizeAI');
let aiOpen = false, aiMinimized = false;

fabAI.addEventListener('click', () => {
  if (!aiOpen) { aiOpen = true; aiPanel.setAttribute('aria-hidden','false'); aiMinimized = false; aiPanel.classList.remove('minimized'); }
  else if (aiMinimized) { aiMinimized = false; aiPanel.classList.remove('minimized'); }
  else { aiOpen = false; aiPanel.setAttribute('aria-hidden','true'); }
});
closeAI.addEventListener('click', () => { aiOpen = false; aiPanel.setAttribute('aria-hidden','true'); });
minimizeAI.addEventListener('click', () => { aiMinimized = !aiMinimized; aiPanel.classList.toggle('minimized', aiMinimized); });

/* tabs */
document.querySelectorAll('.ai-tab').forEach(tab => {
  tab.addEventListener('click', () => {
    document.querySelectorAll('.ai-tab').forEach(t => t.classList.remove('active'));
    document.querySelectorAll('.ai-pane').forEach(p => p.classList.remove('active'));
    tab.classList.add('active');
    document.getElementById('pane-' + tab.dataset.tab).classList.add('active');
  });
});

/* summarize */
const summaryTexts = {
  summary: "GPT-5 has crossed a threshold where its writing quality passes both the Turing test and the editorial test — a significant milestone for AI-generated content.",
  keyPoints: [
    "Large language models now produce prose that editors cannot reliably distinguish from human writing",
    "A 'two-tier content economy' is emerging: mass AI content at the bottom, premium human voice at the top",
    "High-volume content producers are already disrupted; writers with distinctive voice are more insulated",
    "68% of regular readers actively seek signals of human authorship when deciding to trust content",
    "The real risk is intellectual homogenization, not just job displacement"
  ]
};
document.getElementById('summarizeBtn').addEventListener('click', async function() {
  this.classList.add('loading');
  this.textContent = 'Analyzing article…';
  await new Promise(r => setTimeout(r, 1800));
  this.classList.remove('loading');
  this.textContent = '↻ Re-summarize';
  const res = document.getElementById('summaryResult');
  res.innerHTML = `<p>${summaryTexts.summary}</p>
    <div class="key-points">
      <h4>Key Takeaways</h4>
      ${summaryTexts.keyPoints.map(p => `<div class="key-point"><span class="kp-dot"></span><span>${p}</span></div>`).join('')}
    </div>`;
  res.classList.add('visible');
});

/* ask AI */
const aiResponses = {
  "What is the author's main argument?": "The author argues that GPT-5 has crossed a critical threshold — producing writing that can pass editorial scrutiny — creating a bifurcated content economy. Writers with authentic voice and specific expertise will thrive, while those competing on speed and volume face displacement.",
  "What does the two-tier content economy mean?": "The author describes a split: AI-generated content competing on volume and cost at the 'bottom', and premium human-authored writing — with verified expertise, personal perspective, and authentic voice — commanding attention at the 'top'. The middle ground is collapsing, similar to what happened in music and photography.",
  "What evidence does the author provide?": "The author cites: (1) A personal experiment submitting AI-assisted drafts to 12 editors — 9 accepted without style concerns; (2) A Reuters Institute study showing 68% of news readers actively seek signals of human authorship; (3) Industry observations about GPT-5's benchmark scores on creative writing tasks.",
  "Is this article biased in any way?": "The article leans toward qualified optimism for established writers with distinctive voices, while being quite dire about high-volume content producers. There's also an inherent tension: the author runs an AI-powered platform while critiquing AI's effect on writers. Worth noting that the editorial experiment described lacks rigorous controls."
};

function sendAskMessage(text) {
  const msgs = document.getElementById('aiMessages');
  const sugg = document.getElementById('askSuggestions');
  if (sugg) sugg.style.display = 'none';

  const userMsg = document.createElement('div');
  userMsg.className = 'msg-user';
  userMsg.textContent = text;
  msgs.appendChild(userMsg);
  msgs.scrollTop = msgs.scrollHeight;

  const typing = document.createElement('div');
  typing.className = 'typing';
  typing.innerHTML = '<span></span><span></span><span></span>';
  msgs.appendChild(typing);
  msgs.scrollTop = msgs.scrollHeight;

  const delay = 1000 + Math.random() * 700;
  setTimeout(() => {
    typing.remove();
    const aiMsg = document.createElement('div');
    aiMsg.className = 'msg-ai';
    aiMsg.textContent = aiResponses[text] || "Great question! Based on this article, " + text.toLowerCase().replace('?','') + " relates to the broader theme of AI's impact on creative work and the evolving value of human authorship in an AI-saturated content landscape.";
    msgs.appendChild(aiMsg);
    msgs.scrollTop = msgs.scrollHeight;
  }, delay);
}
window.sendAskMessage = sendAskMessage;

document.getElementById('askSendBtn').addEventListener('click', () => {
  const inp = document.getElementById('askInput');
  const text = inp.value.trim();
  if (!text) return;
  inp.value = '';
  sendAskMessage(text);
});
document.getElementById('askInput').addEventListener('keydown', e => {
  if (e.key === 'Enter') {
    const inp = document.getElementById('askInput');
    const text = inp.value.trim();
    if (!text) return;
    inp.value = '';
    sendAskMessage(text);
  }
});

/* explain pane — text selection */
let selectedText = '';
document.getElementById('articleBody').addEventListener('mouseup', () => {
  const sel = window.getSelection();
  const text = sel ? sel.toString().trim() : '';
  if (text.length > 20) {
    selectedText = text;
    const preview = document.getElementById('selectedPreview');
    if (preview) preview.textContent = '"' + text.substring(0, 120) + (text.length > 120 ? '…' : '') + '"';
    showToast('📝 Text selected — open AI → Explain');
  }
});

document.getElementById('explainBtn').addEventListener('click', async function() {
  if (!selectedText) {
    showToast('Select text in the article first!');
    return;
  }
  this.textContent = 'Analyzing…';
  this.style.opacity = '.7';
  await new Promise(r => setTimeout(r, 1600));
  this.textContent = 'Explain selected text';
  this.style.opacity = '';
  const res = document.getElementById('explainResult');
  document.getElementById('explainText').innerHTML = `<p>This passage explores the tension between AI's technical capabilities and the uniquely human elements of creative writing. In plain terms: <strong>the author is saying that while AI can now produce technically excellent writing, it can't replicate the specific life experiences, relationships, and hard-earned expertise that give individual writers their distinctive perspective.</strong></p>
  <p style="margin-top:10px;font-size:13px;color:var(--text-muted);">The underlying idea comes from philosophy of mind — the concept that certain types of knowledge ("tacit knowledge") can only be gained through lived experience, not absorbed from data.</p>`;
  res.classList.add('visible');
});
</script>
</body>
</html>